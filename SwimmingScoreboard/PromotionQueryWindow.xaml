<Window x:Class="SwimmingScoreboard.PromotionQueryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="晋级处理" Width="750" Height="550"
        WindowStartupLocation="CenterOwner" Background="#F1F5F9">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 选择条件 -->
        <Border Grid.Row="0" Background="White" CornerRadius="6" Padding="12" Margin="0,0,0,8">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="性别:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <ComboBox x:Name="GenderCombo" Width="70" SelectionChanged="Gender_Changed" Margin="0,0,12,0">
                        <ComboBoxItem Content="男" IsSelected="True"/>
                        <ComboBoxItem Content="女"/>
                        <ComboBoxItem Content="混合"/>
                    </ComboBox>
                    <TextBlock Text="项目:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <ComboBox x:Name="EventCombo" Width="180" SelectionChanged="Event_Changed" Margin="0,0,12,0"/>
                    <TextBlock Text="赛次:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <ComboBox x:Name="FromStageCombo" Width="80" SelectionChanged="Stage_Changed" Margin="0,0,12,0"/>
                    <Button Content="查询晋级名单" Click="Query_Click" Padding="16,6"
                            Background="#3B82F6" Foreground="White" BorderThickness="0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="晋级方式: 按成绩总排名" VerticalAlignment="Center" Margin="0,0,12,0" FontWeight="Bold" Foreground="#1E40AF"/>
                    <TextBlock Text="晋级人数:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox x:Name="CountBox" Width="50" Text="16" Padding="4" VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 信息提示 -->
        <Border Grid.Row="1" Background="White" CornerRadius="6" Padding="10" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock x:Name="InfoText" Text="" Foreground="#22C55E" FontSize="13" TextWrapping="Wrap"/>
                <TextBlock x:Name="WarningText" Text="" Foreground="#F87171" FontSize="13" TextWrapping="Wrap" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- 晋级名单 -->
        <DataGrid x:Name="PromotionGrid" Grid.Row="2" AutoGenerateColumns="False" CanUserAddRows="False"
                  IsReadOnly="True" AlternatingRowBackground="#F8FAFC" Margin="0,0,0,8">
            <DataGrid.Columns>
                <DataGridTextColumn Header="名次" Binding="{Binding Rank}" Width="45"/>
                <DataGridTextColumn Header="号码" Binding="{Binding BibNumber}" Width="55"/>
                <DataGridTextColumn Header="姓名" Binding="{Binding Name}" Width="75"/>
                <DataGridTextColumn Header="代表队" Binding="{Binding Country}" Width="70"/>
                <DataGridTextColumn Header="组" Binding="{Binding Heat}" Width="35"/>
                <DataGridTextColumn Header="成绩" Binding="{Binding Time}" Width="85"/>
                <DataGridTextColumn Header="反应时间" Binding="{Binding Reaction}" Width="65"/>
                <DataGridTextColumn Header="晋级方式" Binding="{Binding Method}" Width="75"/>
                <DataGridTextColumn Header="晋级到" Binding="{Binding ToStage}" Width="55"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 操作按钮 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <TextBlock x:Name="ResultText" Text="" Foreground="#22C55E" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,16,0"/>
            <Button Content="执行晋级并分组" Click="Execute_Click" Padding="20,8"
                    Background="#22C55E" Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="0,0,8,0"/>
            <Button Content="关闭" Click="Close_Click" Padding="20,8"
                    Background="#475569" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
