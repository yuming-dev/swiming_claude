<Window x:Class="SwimmingScoreboard.PromotionQueryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="晋级处理" Width="700" Height="500"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="项目:" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <ComboBox x:Name="EventCombo" Width="200" SelectionChanged="Event_Changed"/>
            <TextBlock Text=" 从:" VerticalAlignment="Center" Margin="8,0,4,0"/>
            <ComboBox x:Name="FromStageCombo" Width="80">
                <ComboBoxItem Content="预赛" IsSelected="True"/>
                <ComboBoxItem Content="复赛"/>
                <ComboBoxItem Content="半决赛"/>
            </ComboBox>
            <TextBlock Text=" 到:" VerticalAlignment="Center" Margin="8,0,4,0"/>
            <ComboBox x:Name="ToStageCombo" Width="80">
                <ComboBoxItem Content="复赛"/>
                <ComboBoxItem Content="半决赛"/>
                <ComboBoxItem Content="决赛" IsSelected="True"/>
            </ComboBox>
            <TextBlock Text=" 人数:" VerticalAlignment="Center" Margin="8,0,4,0"/>
            <TextBox x:Name="CountBox" Width="40" Text="8" Padding="4"/>
            <Button Content="查询晋级名单" Click="Query_Click" Padding="12,4" Margin="8,0,0,0"
                    Background="#3B82F6" Foreground="White" BorderThickness="0"/>
        </StackPanel>

        <DataGrid x:Name="PromotionGrid" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False"
                  IsReadOnly="True" AlternatingRowBackground="#F8FAFC">
            <DataGrid.Columns>
                <DataGridTextColumn Header="名次" Binding="{Binding Rank}" Width="50"/>
                <DataGridTextColumn Header="号码" Binding="{Binding BibNumber}" Width="60"/>
                <DataGridTextColumn Header="姓名" Binding="{Binding Name}" Width="80"/>
                <DataGridTextColumn Header="代表队" Binding="{Binding Country}" Width="80"/>
                <DataGridTextColumn Header="成绩" Binding="{Binding Time}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="执行晋级" Click="Execute_Click" Padding="16,6"
                    Background="#22C55E" Foreground="White" BorderThickness="0" Margin="0,0,8,0"/>
            <Button Content="关闭" Click="Close_Click" Padding="16,6"/>
        </StackPanel>
    </Grid>
</Window>
