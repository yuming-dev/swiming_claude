<Window x:Class="SwimmingScoreboard.DocumentPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="文档预览 / 输出"
        Width="1100" Height="780"
        WindowStartupLocation="CenterOwner"
        Background="#F8FAFC">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#1E40AF" Padding="16,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="TitleText" Text="文档预览" FontSize="17" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                <TextBlock Text="　·　可在编辑选项卡修改 HTML 后重新预览" Foreground="#DBEAFE" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#E2E8F0" Padding="14,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="刷新预览" Click="Refresh_Click" Background="#94A3B8"
                        ToolTip="将&quot;编辑源码&quot;选项卡中的修改应用到预览"/>
                <Button Content="在浏览器中打开" Click="OpenBrowser_Click" Background="#0EA5E9"
                        ToolTip="在系统默认浏览器中打开当前文档（可在浏览器中按 Ctrl+P 打印或另存为 PDF）"/>
                <Button Content="导出 PDF" Click="ExportPdf_Click" Background="#DC2626"
                        ToolTip="在浏览器中打开后选择&quot;Microsoft Print to PDF&quot;打印机即可保存为 PDF"/>
                <Button Content="导出 DOC" Click="ExportDoc_Click" Background="#2563EB"
                        ToolTip="保存为 Microsoft Word 兼容的 .doc 文件"/>
                <Button Content="导出 HTML" Click="ExportHtml_Click" Background="#7C3AED"
                        ToolTip="保存为 .html 文件"/>
                <Button Content="打印" Click="Print_Click" Background="#22C55E"
                        ToolTip="使用系统打印机打印"/>
                <Button Content="关闭" Click="Close_Click" Background="#475569"/>
            </StackPanel>
        </Border>

        <TabControl Margin="10">
            <TabItem Header="预览">
                <WebBrowser x:Name="Preview" />
            </TabItem>
            <TabItem Header="编辑源码（HTML）">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Margin="6,4" Foreground="#475569"
                               Text="可直接修改下方 HTML 源码，点击&quot;刷新预览&quot;查看效果，再点击&quot;导出 DOC/PDF/HTML&quot;输出。"/>
                    <TextBox x:Name="HtmlEditor" AcceptsReturn="True" AcceptsTab="True"
                             FontFamily="Consolas,Courier New" FontSize="12"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                             TextWrapping="NoWrap" Padding="6"/>
                </DockPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
