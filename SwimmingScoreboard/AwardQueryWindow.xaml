<Window x:Class="SwimmingScoreboard.AwardQueryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="颁奖查询" Width="600" Height="400"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="颁奖查询窗口" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
        <DataGrid x:Name="AwardGrid" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="名次" Binding="{Binding Rank}" Width="50"/>
                <DataGridTextColumn Header="姓名" Binding="{Binding Name}" Width="100"/>
                <DataGridTextColumn Header="代表队" Binding="{Binding Country}" Width="100"/>
                <DataGridTextColumn Header="成绩" Binding="{Binding Time}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
