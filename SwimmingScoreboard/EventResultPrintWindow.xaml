<Window x:Class="SwimmingScoreboard.EventResultPrintWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="项目成绩打印" Width="700" Height="500"
        WindowStartupLocation="CenterOwner" Background="#F1F5F9">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 选择条件 -->
        <Border Grid.Row="0" Background="White" CornerRadius="6" Padding="12" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="性别:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <ComboBox x:Name="GenderCombo" Width="70" SelectionChanged="Filter_Changed" Margin="0,0,12,0">
                    <ComboBoxItem Content="男" IsSelected="True"/>
                    <ComboBoxItem Content="女"/>
                    <ComboBoxItem Content="混合"/>
                </ComboBox>
                <TextBlock Text="项目:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <ComboBox x:Name="EventCombo" Width="180" SelectionChanged="Filter_Changed" Margin="0,0,12,0"/>
                <TextBlock Text="赛次:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <ComboBox x:Name="StageCombo" Width="80" SelectionChanged="Filter_Changed" Margin="0,0,12,0">
                    <ComboBoxItem Content="预赛" IsSelected="True"/>
                    <ComboBoxItem Content="半决赛"/>
                    <ComboBoxItem Content="决赛"/>
                </ComboBox>
                <TextBlock Text="组:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <ComboBox x:Name="HeatCombo" Width="80" SelectionChanged="Heat_Changed" Margin="0,0,12,0">
                    <ComboBoxItem Content="全部" IsSelected="True"/>
                </ComboBox>
                <Button Content="查询" Click="Query_Click" Padding="16,6"
                        Background="#3B82F6" Foreground="White" BorderThickness="0"/>
            </StackPanel>
        </Border>

        <!-- 状态提示 -->
        <Border Grid.Row="1" Background="White" CornerRadius="6" Padding="10" Margin="0,0,0,8">
            <TextBlock x:Name="StatusText" Text="请选择条件后点击查询" Foreground="#64748B" FontSize="13"/>
        </Border>

        <!-- 预览表格 -->
        <DataGrid x:Name="PreviewGrid" Grid.Row="2" AutoGenerateColumns="False" CanUserAddRows="False"
                  IsReadOnly="True" AlternatingRowBackground="#F8FAFC" Margin="0,0,0,8">
            <DataGrid.Columns>
                <DataGridTextColumn Header="名次" Binding="{Binding Rank}" Width="50"/>
                <DataGridTextColumn Header="道" Binding="{Binding Lane}" Width="40"/>
                <DataGridTextColumn Header="号码" Binding="{Binding BibNumber}" Width="60"/>
                <DataGridTextColumn Header="姓名" Binding="{Binding Name}" Width="80"/>
                <DataGridTextColumn Header="代表队" Binding="{Binding Country}" Width="80"/>
                <DataGridTextColumn Header="最终成绩" Binding="{Binding FinalTime}" Width="80"/>
                <DataGridTextColumn Header="成绩差" Binding="{Binding Diff}" Width="70"/>
                <DataGridTextColumn Header="反应时间" Binding="{Binding ReactionTime}" Width="70"/>
                <DataGridTextColumn Header="备注" Binding="{Binding Remark}" Width="50"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 操作按钮 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="打印输出" Click="Print_Click" Padding="20,8"
                    Background="#22C55E" Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="0,0,8,0"
                    x:Name="PrintButton" IsEnabled="False"/>
            <Button Content="关闭" Click="Close_Click" Padding="20,8"
                    Background="#475569" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
