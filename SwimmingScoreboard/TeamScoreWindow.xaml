<Window x:Class="SwimmingScoreboard.TeamScoreWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="团体成绩" Width="800" Height="500"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="团体成绩排名" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
        <DataGrid x:Name="TeamGrid" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False"
                  IsReadOnly="True" AlternatingRowBackground="#F8FAFC">
            <DataGrid.Columns>
                <DataGridTextColumn Header="名次" Binding="{Binding Rank}" Width="50"/>
                <DataGridTextColumn Header="代表队" Binding="{Binding TeamName}" Width="100"/>
                <DataGridTextColumn Header="总分" Binding="{Binding TotalPoints}" Width="70"/>
                <DataGridTextColumn Header="个人分" Binding="{Binding IndividualPoints}" Width="70"/>
                <DataGridTextColumn Header="接力分" Binding="{Binding RelayPoints}" Width="70"/>
                <DataGridTextColumn Header="破纪录加分" Binding="{Binding RecordBonusPoints}" Width="80"/>
                <DataGridTextColumn Header="金牌" Binding="{Binding GoldCount}" Width="50"/>
                <DataGridTextColumn Header="银牌" Binding="{Binding SilverCount}" Width="50"/>
                <DataGridTextColumn Header="铜牌" Binding="{Binding BronzeCount}" Width="50"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
