<Window x:Class="SwimmingScoreboard.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="游泳赛事管理系统 — 登录" Height="320" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#1E293B" WindowStyle="SingleBorderWindow">
    <Grid Margin="40,30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="28"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="游泳赛事管理系统" FontSize="20" FontWeight="Bold"
                   Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,5"/>
        <TextBlock Grid.Row="1" Text="请输入管理员账号登录" FontSize="13"
                   Foreground="#94A3B8" HorizontalAlignment="Center"/>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="用户名" Foreground="#CBD5E1" VerticalAlignment="Center"/>
            <TextBox x:Name="UsernameBox" Grid.Column="1" Padding="8,6" FontSize="14"
                     Background="#334155" Foreground="White" BorderBrush="#475569" BorderThickness="1"
                     CaretBrush="White"/>
        </Grid>

        <Grid Grid.Row="4" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="密  码" Foreground="#CBD5E1" VerticalAlignment="Center"/>
            <PasswordBox x:Name="PasswordBox" Grid.Column="1" Padding="8,6" FontSize="14"
                         Background="#334155" Foreground="White" BorderBrush="#475569" BorderThickness="1"/>
        </Grid>

        <CheckBox x:Name="RememberMe" Grid.Row="5" Content="记住登录名和密码" Margin="0,10,0,0"
                  Foreground="#CBD5E1" FontSize="12"/>

        <TextBlock x:Name="ErrorText" Grid.Row="6" Text="" Foreground="#F87171"
                   HorizontalAlignment="Center" FontSize="12" Margin="0,6,0,0" Visibility="Collapsed"/>

        <Button Grid.Row="7" Content="登  录" Click="Login_Click" Margin="0,10,0,0"
                Background="#3B82F6" Foreground="White" FontSize="15" FontWeight="Bold"
                Padding="0,10" BorderThickness="0"/>
    </Grid>
</Window>
