<Window x:Class="SwimmingScoreboard.HeatImportPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="导入分组表"
        Width="520" Height="260"
        WindowStartupLocation="CenterOwner"
        Background="#F8FAFC"
        ResizeMode="NoResize">
    <DockPanel Margin="20">
        <Border DockPanel.Dock="Top" Background="#0EA5E9" Padding="14,10" Margin="0,0,0,14">
            <TextBlock Text="导入分组表 (Excel)" Foreground="White" FontSize="16" FontWeight="Bold"/>
        </Border>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="取消" Click="Cancel_Click" Padding="20,7" Margin="6,0,0,0" Background="#94A3B8" Foreground="White" BorderThickness="0"/>
            <Button Content="开始导入" Click="Ok_Click" Padding="20,7" Margin="6,0,0,0" Background="#22C55E" Foreground="White" BorderThickness="0"/>
        </StackPanel>

        <StackPanel>
            <TextBlock TextWrapping="Wrap" Foreground="#475569" FontSize="13" Margin="0,0,0,12">
                即将导入分组表。<LineBreak/>
                匹配规则：参赛号 → 姓名+代表队；导入会覆盖相应项目/赛次的现有分组。
            </TextBlock>
            <CheckBox x:Name="AutoRegisterBox" IsChecked="True" FontSize="13" Margin="0,4,0,0">
                <TextBlock TextWrapping="Wrap">
                    <Run Text="未注册时自动添加" FontWeight="Bold"/>
                    <LineBreak/>
                    <Run Text="若 Excel 中的姓名+代表队 在系统里找不到，则自动按该行信息新建一名运动员（含姓名 / 性别 / 代表队 / 项目 / 报名成绩 / 出生日期 / 年龄 / 组别）。"
                         Foreground="#64748B" FontSize="11"/>
                </TextBlock>
            </CheckBox>
        </StackPanel>
    </DockPanel>
</Window>
