<Window x:Class="SwimmingScoreboard.DeviceStatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设备状态管理" Width="800" Height="500"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="泳道设备好/坏状态设置" FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <DataGrid x:Name="DeviceGrid" AutoGenerateColumns="False" CanUserAddRows="False"
                      IsReadOnly="False" AlternatingRowBackground="#F8FAFC" HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="道次" Binding="{Binding Lane}" Width="50" IsReadOnly="True"/>
                    <DataGridCheckBoxColumn Header="左触板坏" Binding="{Binding LeftTouchpadBroken}" Width="70"/>
                    <DataGridCheckBoxColumn Header="左出发台坏" Binding="{Binding LeftStartBlockBroken}" Width="80"/>
                    <DataGridCheckBoxColumn Header="左盲表坏" Binding="{Binding LeftBlindWatchBroken}" Width="70"/>
                    <DataGridCheckBoxColumn Header="右触板坏" Binding="{Binding RightTouchpadBroken}" Width="70"/>
                    <DataGridCheckBoxColumn Header="右出发台坏" Binding="{Binding RightStartBlockBroken}" Width="80"/>
                    <DataGridCheckBoxColumn Header="右盲表坏" Binding="{Binding RightBlindWatchBroken}" Width="70"/>
                </DataGrid.Columns>
            </DataGrid>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="全部设为好" Click="AllGood_Click" Padding="16,6" Margin="0,0,8,0"/>
            <Button Content="全部设为坏" Click="AllBad_Click" Padding="16,6" Margin="0,0,16,0"/>
            <Button Content="确定" Click="OK_Click" Padding="16,6" Background="#3B82F6" Foreground="White" BorderThickness="0" Margin="0,0,8,0"/>
            <Button Content="取消" Click="Cancel_Click" Padding="16,6"/>
        </StackPanel>
    </Grid>
</Window>
