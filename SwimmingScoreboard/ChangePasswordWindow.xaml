<Window x:Class="SwimmingScoreboard.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="修改账号密码" Height="370" Width="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#1E293B">
    <Grid Margin="40,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="22"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="修改账号密码" FontSize="18" FontWeight="Bold"
                   Foreground="White" HorizontalAlignment="Center"/>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <TextBlock Text="当前密码" Foreground="#CBD5E1" VerticalAlignment="Center"/>
            <PasswordBox x:Name="CurrentPasswordBox" Grid.Column="1" Padding="8,6" FontSize="13"
                         Background="#334155" Foreground="White" BorderBrush="#475569" BorderThickness="1"/>
        </Grid>

        <Grid Grid.Row="3" Margin="0,10,0,0">
            <Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <TextBlock Text="新用户名" Foreground="#CBD5E1" VerticalAlignment="Center"/>
            <TextBox x:Name="NewUsernameBox" Grid.Column="1" Padding="8,6" FontSize="13"
                     Background="#334155" Foreground="White" BorderBrush="#475569" BorderThickness="1"
                     CaretBrush="White"/>
        </Grid>

        <Grid Grid.Row="4" Margin="0,10,0,0">
            <Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <TextBlock Text="新密码" Foreground="#CBD5E1" VerticalAlignment="Center"/>
            <PasswordBox x:Name="NewPasswordBox" Grid.Column="1" Padding="8,6" FontSize="13"
                         Background="#334155" Foreground="White" BorderBrush="#475569" BorderThickness="1"/>
        </Grid>

        <Grid Grid.Row="5" Margin="0,10,0,0">
            <Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <TextBlock Text="确认密码" Foreground="#CBD5E1" VerticalAlignment="Center"/>
            <PasswordBox x:Name="ConfirmPasswordBox" Grid.Column="1" Padding="8,6" FontSize="13"
                         Background="#334155" Foreground="White" BorderBrush="#475569" BorderThickness="1"/>
        </Grid>

        <TextBlock x:Name="MessageText" Grid.Row="7" Text="" HorizontalAlignment="Center"
                   FontSize="12" Margin="0,0,0,8" TextWrapping="Wrap"/>

        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="保存修改" Click="Save_Click" Width="100" Padding="0,8"
                    Background="#3B82F6" Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="0,0,15,0"/>
            <Button Content="取消" Click="Cancel_Click" Width="80" Padding="0,8"
                    Background="#475569" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
