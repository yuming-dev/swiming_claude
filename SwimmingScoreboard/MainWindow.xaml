<Window x:Class="SwimmingScoreboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:System="clr-namespace:System;assembly=mscorlib"
        xmlns:local="clr-namespace:SwimmingScoreboard"
        Title="游泳竞赛管理系统 - 专业版" Height="900" Width="1600" Background="#F1F5F9">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <local:StringToDateConverter x:Key="StringToDateConverter" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部状态栏 -->
        <Border Grid.Row="0" Background="#1E293B" Padding="10,5">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="● 竞赛服务运行中" Foreground="#22C55E" VerticalAlignment="Center" FontWeight="Bold"/>
                <TextBlock Text=" | WebSocket: ws://0.0.0.0:3002" Foreground="#FACC15" VerticalAlignment="Center" FontWeight="Bold" Margin="15,0"/>
                <TextBlock Text=" | 已连接终端: " Foreground="#94A3B8" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding ConnectionCount}" Foreground="#FACC15" VerticalAlignment="Center" FontWeight="Bold"/>
                <TextBlock Text=" (请确保同一WiFi)" Foreground="#64748B" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="11"/>
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1" Margin="10">
            <!-- ============ Tab 1: 赛事管理与报名 ============ -->
            <TabItem Header="赛事管理与报名">
                <Grid Margin="15">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>

                    <!-- 顶部配置区 -->
                    <Border Grid.Row="0" Background="#F8FAFC" Padding="20" CornerRadius="10" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,0,15">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/><ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/><ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="30"/><ColumnDefinition Width="180"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="比赛名称" VerticalAlignment="Center" FontWeight="Bold"/>
                                <TextBox Grid.Column="1" Text="{Binding CompetitionName}" Padding="8" Margin="10,0,30,0" FontSize="16" BorderBrush="#3B82F6"/>
                                <TextBlock Grid.Column="2" Text="比赛日期" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0"/>
                                <DatePicker Grid.Column="3" SelectedDate="{Binding StartDate}" VerticalAlignment="Center" Padding="5"/>
                                <TextBlock Grid.Column="4" Text="至" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <DatePicker Grid.Column="5" SelectedDate="{Binding EndDate}" VerticalAlignment="Center" Padding="5"/>
                            </Grid>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="查看/管理全场报名表" Click="ShowRegistrationList_Click" Padding="25,10" Background="#22C55E" Foreground="White" FontWeight="Bold" Margin="0,0,15,0"/>
                                <Button Content="一键分配参赛号码" Click="AssignBibNumbers_Click" Padding="15,5" Background="#3B82F6" Foreground="White" Margin="0,0,10,0"/>
                                <Button Content="执行全场晋级处理" Click="ProcessPromotion_Click" Padding="15,5" Background="#F59E0B" Foreground="White"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="380"/></Grid.ColumnDefinitions>

                        <!-- 左侧：子Tab -->
                        <TabControl Background="White" Margin="0,0,15,0">
                            <!-- A: 运动员报名 -->
                            <TabItem Header="运动员报名">
                                <Grid Margin="15">
                                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                    <GroupBox Header="运动员信息录入" Padding="15" BorderBrush="#3B82F6">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <StackPanel Margin="5"><TextBlock Text="姓名" FontWeight="Bold"/><TextBox x:Name="RegName" Padding="5"/></StackPanel>
                                                <StackPanel Grid.Column="1" Margin="5"><TextBlock Text="性别" FontWeight="Bold"/><ComboBox x:Name="RegGender" Padding="4"><System:String>男</System:String><System:String>女</System:String></ComboBox></StackPanel>
                                                <StackPanel Grid.Column="2" Margin="5"><TextBlock Text="出生日期" FontWeight="Bold"/><DatePicker x:Name="RegBirthPicker" Padding="3"/></StackPanel>
                                            </Grid>
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <StackPanel Margin="5"><TextBlock Text="参赛单位" FontWeight="Bold"/><TextBox x:Name="RegOrg" Padding="5"/></StackPanel>
                                                <StackPanel Grid.Column="1" Margin="5"><TextBlock Text="年龄组" FontWeight="Bold"/><ComboBox x:Name="RegAgeGroup" Padding="4"><System:String>儿童组</System:String><System:String>少年组</System:String><System:String>青年组</System:String><System:String>公开组</System:String></ComboBox></StackPanel>
                                                <StackPanel Grid.Column="2" Margin="5"><TextBlock Text="联系电话" FontWeight="Bold"/><TextBox x:Name="RegPhone" Padding="5"/></StackPanel>
                                            </Grid>

                                            <Separator Height="10" Background="Transparent"/>

                                            <!-- 参赛项目区 -->
                                            <Border Background="#EFF6FF" Padding="15" CornerRadius="8" BorderBrush="#BFDBFE" BorderThickness="1">
                                                <StackPanel>
                                                    <TextBlock Text="参赛项目（选择项目并填写报名成绩）" FontWeight="Bold" Foreground="#1E40AF" Margin="0,0,0,10"/>
                                                    <!-- 项目1 -->
                                                    <Grid Margin="0,0,0,5">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="50"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="项目1" VerticalAlignment="Center" FontWeight="Bold"/>
                                                        <ComboBox Grid.Column="1" x:Name="RegDist1" Padding="4" Margin="5,0">
                                                            <System:String>50米</System:String><System:String>100米</System:String><System:String>200米</System:String><System:String>400米</System:String><System:String>800米</System:String><System:String>1500米</System:String><System:String>4x100米接力</System:String><System:String>4x200米接力</System:String>
                                                        </ComboBox>
                                                        <ComboBox Grid.Column="2" x:Name="RegStroke1" Padding="4" Margin="5,0">
                                                            <System:String>自由泳</System:String><System:String>蛙泳</System:String><System:String>蝶泳</System:String><System:String>仰泳</System:String><System:String>混合泳</System:String>
                                                        </ComboBox>
                                                        <TextBox Grid.Column="3" x:Name="RegTime1" Padding="4" Margin="5,0" ToolTip="报名成绩 格式: ss.ff 或 m:ss.ff"/>
                                                    </Grid>
                                                    <!-- 项目2 -->
                                                    <Grid Margin="0,0,0,5">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="50"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="项目2" VerticalAlignment="Center"/>
                                                        <ComboBox Grid.Column="1" x:Name="RegDist2" Padding="4" Margin="5,0">
                                                            <System:String>50米</System:String><System:String>100米</System:String><System:String>200米</System:String><System:String>400米</System:String><System:String>800米</System:String><System:String>1500米</System:String>
                                                        </ComboBox>
                                                        <ComboBox Grid.Column="2" x:Name="RegStroke2" Padding="4" Margin="5,0">
                                                            <System:String>自由泳</System:String><System:String>蛙泳</System:String><System:String>蝶泳</System:String><System:String>仰泳</System:String><System:String>混合泳</System:String>
                                                        </ComboBox>
                                                        <TextBox Grid.Column="3" x:Name="RegTime2" Padding="4" Margin="5,0" ToolTip="报名成绩"/>
                                                    </Grid>
                                                    <!-- 项目3 -->
                                                    <Grid Margin="0,0,0,5">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="50"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="项目3" VerticalAlignment="Center"/>
                                                        <ComboBox Grid.Column="1" x:Name="RegDist3" Padding="4" Margin="5,0">
                                                            <System:String>50米</System:String><System:String>100米</System:String><System:String>200米</System:String><System:String>400米</System:String><System:String>800米</System:String><System:String>1500米</System:String>
                                                        </ComboBox>
                                                        <ComboBox Grid.Column="2" x:Name="RegStroke3" Padding="4" Margin="5,0">
                                                            <System:String>自由泳</System:String><System:String>蛙泳</System:String><System:String>蝶泳</System:String><System:String>仰泳</System:String><System:String>混合泳</System:String>
                                                        </ComboBox>
                                                        <TextBox Grid.Column="3" x:Name="RegTime3" Padding="4" Margin="5,0" ToolTip="报名成绩"/>
                                                    </Grid>

                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                                                        <Button Content="清空重填" Click="ClearRegForm_Click" Padding="15,5" Margin="0,0,10,0"/>
                                                        <Button Content="从文件导入" Click="ImportFromExcel_Click" Padding="15,5" Margin="0,0,10,0"/>
                                                        <Button Content="添加此选手" Click="ManualRegister_Click" Padding="25,8" Background="#3B82F6" Foreground="White" FontWeight="Bold" Margin="0,0,10,0"/>
                                                        <Button Content="全部提交保存" Click="FinalizeRegistration_Click" Padding="30,8" Background="#22C55E" Foreground="White" FontWeight="Bold"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </GroupBox>
                                    <GroupBox Grid.Row="1" Header="当前已报名预览" Margin="0,10,0,0">
                                        <DataGrid ItemsSource="{Binding Swimmers}" AutoGenerateColumns="False" IsReadOnly="True" RowHeight="28" FontSize="11">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="姓名" Binding="{Binding Name}" Width="70"/>
                                                <DataGridTextColumn Header="性别" Binding="{Binding Gender}" Width="40"/>
                                                <DataGridTextColumn Header="单位" Binding="{Binding Organization}" Width="80"/>
                                                <DataGridTextColumn Header="年龄组" Binding="{Binding AgeGroup}" Width="60"/>
                                                <DataGridTextColumn Header="项目" Binding="{Binding EventId}" Width="120"/>
                                                <DataGridTextColumn Header="报名成绩" Binding="{Binding ReportedTimeDisplay}" Width="80"/>
                                                <DataGridTextColumn Header="阶段" Binding="{Binding Stage}" Width="50"/>
                                                <DataGridTextColumn Header="组" Binding="{Binding HeatNumber}" Width="35"/>
                                                <DataGridTextColumn Header="道" Binding="{Binding Lane}" Width="35"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </GroupBox>
                                </Grid>
                            </TabItem>

                            <!-- B: 接力报名 -->
                            <TabItem Header="接力报名">
                                <Grid Margin="15">
                                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                    <GroupBox Header="接力队伍登记" Padding="15" BorderBrush="#3B82F6">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <StackPanel Margin="5"><TextBlock Text="参赛单位" FontWeight="Bold"/><TextBox x:Name="RelayTeamName" Padding="5"/></StackPanel>
                                                <StackPanel Grid.Column="1" Margin="5"><TextBlock Text="接力项目" FontWeight="Bold"/><ComboBox x:Name="RelayEvent" Padding="4"><System:String>男子4x100米自由泳接力</System:String><System:String>女子4x100米自由泳接力</System:String><System:String>男子4x200米自由泳接力</System:String><System:String>女子4x200米自由泳接力</System:String><System:String>男子4x100米混合泳接力</System:String><System:String>女子4x100米混合泳接力</System:String><System:String>混合4x100米自由泳接力</System:String><System:String>混合4x100米混合泳接力</System:String></ComboBox></StackPanel>
                                                <StackPanel Grid.Column="2" Margin="5"><TextBlock Text="报名成绩" FontWeight="Bold"/><TextBox x:Name="RelayTime" Padding="5" ToolTip="格式: m:ss.ff"/></StackPanel>
                                            </Grid>
                                            <Grid Margin="0,10,0,0">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <StackPanel Margin="5"><TextBlock Text="第一棒" FontWeight="Bold"/><TextBox x:Name="RelayMember1" Padding="5"/></StackPanel>
                                                <StackPanel Grid.Column="1" Margin="5"><TextBlock Text="第二棒" FontWeight="Bold"/><TextBox x:Name="RelayMember2" Padding="5"/></StackPanel>
                                                <StackPanel Grid.Column="2" Margin="5"><TextBlock Text="第三棒" FontWeight="Bold"/><TextBox x:Name="RelayMember3" Padding="5"/></StackPanel>
                                                <StackPanel Grid.Column="3" Margin="5"><TextBlock Text="第四棒" FontWeight="Bold"/><TextBox x:Name="RelayMember4" Padding="5"/></StackPanel>
                                            </Grid>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                                                <Button Content="添加接力队" Click="AddRelayTeam_Click" Padding="25,8" Background="#3B82F6" Foreground="White" FontWeight="Bold"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </GroupBox>
                                    <GroupBox Grid.Row="1" Header="已登记接力队预览" Margin="0,10,0,0">
                                        <DataGrid ItemsSource="{Binding RelayTeams}" AutoGenerateColumns="False" IsReadOnly="True" RowHeight="28" FontSize="11">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="单位" Binding="{Binding TeamName}" Width="100"/>
                                                <DataGridTextColumn Header="项目" Binding="{Binding EventId}" Width="180"/>
                                                <DataGridTextColumn Header="队员" Binding="{Binding MembersSummary}" Width="*"/>
                                                <DataGridTextColumn Header="报名成绩" Binding="{Binding ReportedTimeDisplay}" Width="80"/>
                                                <DataGridTextColumn Header="阶段" Binding="{Binding Stage}" Width="50"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </GroupBox>
                                </Grid>
                            </TabItem>

                            <!-- C: 组织信息 -->
                            <TabItem Header="组织信息">
                                <Grid Margin="15">
                                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                    <GroupBox Header="添加参赛单位" Padding="15" BorderBrush="#3B82F6">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <StackPanel Margin="5"><TextBlock Text="单位名称" FontWeight="Bold"/><TextBox x:Name="OrgName" Padding="5"/></StackPanel>
                                                <StackPanel Grid.Column="1" Margin="5"><TextBlock Text="领队" FontWeight="Bold"/><TextBox x:Name="OrgLeader" Padding="5"/></StackPanel>
                                                <StackPanel Grid.Column="2" Margin="5"><TextBlock Text="教练" FontWeight="Bold"/><TextBox x:Name="OrgCoach" Padding="5"/></StackPanel>
                                                <StackPanel Grid.Column="3" Margin="5"><TextBlock Text="电话" FontWeight="Bold"/><TextBox x:Name="OrgPhone" Padding="5"/></StackPanel>
                                            </Grid>
                                            <Button Content="添加单位" Click="AddOrganization_Click" HorizontalAlignment="Right" Padding="20,5" Background="#3B82F6" Foreground="White" Margin="0,10,0,0"/>
                                        </StackPanel>
                                    </GroupBox>
                                    <DataGrid Grid.Row="1" ItemsSource="{Binding Organizations}" AutoGenerateColumns="False" IsReadOnly="True" Margin="0,10,0,0" RowHeight="32">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="单位名称" Binding="{Binding Name}" Width="200"/>
                                            <DataGridTextColumn Header="领队" Binding="{Binding LeaderName}" Width="100"/>
                                            <DataGridTextColumn Header="教练" Binding="{Binding CoachName}" Width="100"/>
                                            <DataGridTextColumn Header="电话" Binding="{Binding Phone}" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </TabItem>

                            <!-- D: 赛事概览 -->
                            <TabItem Header="赛事概览">
                                <Grid Margin="30">
                                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                    <StackPanel><TextBlock Text="赛事指挥与数据概览" FontSize="22" FontWeight="900" Foreground="#1E293B"/><Separator Height="20" Background="Transparent"/></StackPanel>
                                    <UniformGrid Grid.Row="1" Columns="2" Rows="2">
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"><TextBlock Text="总报名人次" Foreground="#64748B" HorizontalAlignment="Center"/><TextBlock Text="{Binding TotalRegistrationCount}" FontSize="48" FontWeight="Bold" Foreground="#3B82F6" HorizontalAlignment="Center"/></StackPanel>
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"><TextBlock Text="比赛项目数" Foreground="#64748B" HorizontalAlignment="Center"/><TextBlock Text="{Binding EventsCount}" FontSize="48" FontWeight="Bold" Foreground="#10B981" HorizontalAlignment="Center"/></StackPanel>
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"><TextBlock Text="接力队数" Foreground="#64748B" HorizontalAlignment="Center"/><TextBlock Text="{Binding RelayTeamsCount}" FontSize="48" FontWeight="Bold" Foreground="#F59E0B" HorizontalAlignment="Center"/></StackPanel>
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"><TextBlock Text="参赛单位数" Foreground="#64748B" HorizontalAlignment="Center"/><TextBlock Text="{Binding OrganizationsCount}" FontSize="48" FontWeight="Bold" Foreground="#8B5CF6" HorizontalAlignment="Center"/></StackPanel>
                                    </UniformGrid>
                                </Grid>
                            </TabItem>

                            <!-- E: 竞赛官员 -->
                            <TabItem Header="竞赛官员">
                                <GroupBox Header="竞赛官员与裁判名单" Margin="10" Padding="10">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,10"><Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="裁判长" VerticalAlignment="Center"/><TextBox Grid.Column="1" Text="{Binding OfficialReferee}" Padding="5"/></Grid>
                                            <Grid Margin="0,0,0,10"><Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="发令员" VerticalAlignment="Center"/><TextBox Grid.Column="1" Text="{Binding OfficialStarter}" Padding="5"/></Grid>
                                            <Grid Margin="0,0,0,10"><Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="计时长" VerticalAlignment="Center"/><TextBox Grid.Column="1" Text="{Binding OfficialChiefTimekeeper}" Padding="5"/></Grid>
                                            <TextBlock Text="途中裁判 (可多行输入)" Margin="0,10,0,5" FontWeight="Bold"/><TextBox Text="{Binding OfficialStrokeJudges}" Height="100" TextWrapping="Wrap" AcceptsReturn="True" Padding="5"/>
                                            <TextBlock Text="转身裁判 (可多行输入)" Margin="0,10,0,5" FontWeight="Bold"/><TextBox Text="{Binding OfficialTurnJudges}" Height="100" TextWrapping="Wrap" AcceptsReturn="True" Padding="5"/>
                                            <Grid Margin="0,15,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="记录长" VerticalAlignment="Center"/><TextBox Grid.Column="1" Text="{Binding OfficialSecretary}" Padding="5"/></Grid>
                                        </StackPanel>
                                    </ScrollViewer>
                                </GroupBox>
                            </TabItem>

                            <!-- F: 日程管理 -->
                            <TabItem Header="日程管理">
                                <Grid Margin="10">
                                    <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                    <DataGrid ItemsSource="{Binding DailySchedule}" AutoGenerateColumns="False" CanUserAddRows="True">
                                        <DataGrid.Columns>
                                            <DataGridTemplateColumn Header="日期" Width="150">
                                                <DataGridTemplateColumn.CellTemplate><DataTemplate><TextBlock Text="{Binding Date}" VerticalAlignment="Center" HorizontalAlignment="Center"/></DataTemplate></DataGridTemplateColumn.CellTemplate>
                                                <DataGridTemplateColumn.CellEditingTemplate><DataTemplate><DatePicker SelectedDate="{Binding Date, Mode=TwoWay, Converter={StaticResource StringToDateConverter}}"/></DataTemplate></DataGridTemplateColumn.CellEditingTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="时间" Width="120">
                                                <DataGridTemplateColumn.CellTemplate><DataTemplate><TextBlock Text="{Binding Time}" VerticalAlignment="Center" HorizontalAlignment="Center"/></DataTemplate></DataGridTemplateColumn.CellTemplate>
                                                <DataGridTemplateColumn.CellEditingTemplate><DataTemplate><ComboBox ItemsSource="{Binding DataContext.TimeOptions, RelativeSource={RelativeSource AncestorType=Window}}" SelectedItem="{Binding Time, Mode=TwoWay}" IsEditable="True"/></DataTemplate></DataGridTemplateColumn.CellEditingTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Header="项目内容" Binding="{Binding Event}" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                                        <Button Content="一键生成日程" Click="GenerateSchedule_Click" Margin="0,0,10,0" Padding="15,5" Background="#F59E0B" Foreground="White"/>
                                        <Button Content="导出日程表" Click="PrintSchedule_Click" Padding="15,5" Background="#3B82F6" Foreground="White"/>
                                    </StackPanel>
                                </Grid>
                            </TabItem>

                            <!-- G: 编排统计 -->
                            <TabItem Header="编排数据统计">
                                <DataGrid ItemsSource="{Binding EventSummaries}" AutoGenerateColumns="False" IsReadOnly="True" Margin="10" RowHeight="35">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="项目名称" Binding="{Binding EventName}" Width="300"/>
                                        <DataGridTextColumn Header="人数" Binding="{Binding AthleteCount}" Width="80"/>
                                        <DataGridTextColumn Header="组数" Binding="{Binding HeatCount}" Width="80"/>
                                        <DataGridTextColumn Header="最好报名成绩" Binding="{Binding BestTimeDisplay}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>

                            <!-- H: 编排微调 -->
                            <TabItem Header="编排微调">
                                <Grid>
                                    <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding GroupedSwimmersView}" Margin="10">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <GroupBox Header="{Binding GroupName}" Margin="0,0,0,15" BorderBrush="#3B82F6" BorderThickness="1">
                                                        <DataGrid ItemsSource="{Binding Members}" AutoGenerateColumns="False" IsReadOnly="False" RowHeight="30" CellEditEnding="DataGrid_CellEditEnding">
                                                            <DataGrid.Columns>
                                                                <DataGridTextColumn Header="组次" Binding="{Binding HeatNumber, UpdateSourceTrigger=PropertyChanged}" Width="50" FontWeight="Bold" Foreground="#1E40AF"/>
                                                                <DataGridTextColumn Header="泳道" Binding="{Binding Lane, UpdateSourceTrigger=PropertyChanged}" Width="50"/>
                                                                <DataGridTextColumn Header="姓名" Binding="{Binding Name}" Width="100" IsReadOnly="True"/>
                                                                <DataGridTextColumn Header="单位" Binding="{Binding Organization}" Width="100" IsReadOnly="True"/>
                                                                <DataGridTextColumn Header="报名成绩" Binding="{Binding ReportedTimeDisplay}" Width="80" IsReadOnly="True"/>
                                                            </DataGrid.Columns>
                                                        </DataGrid>
                                                    </GroupBox>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                    <Border Grid.Row="1" Background="#F8FAFC" Padding="10">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <TextBlock Text="※ 修改上方[组次/泳道]后点击应用 →" VerticalAlignment="Center" Margin="0,0,15,0" Foreground="Gray" FontStyle="Italic"/>
                                            <Button Content="应用微调并刷新视图" Click="ApplyManualAdjustment_Click" Padding="15,5" Background="#3B82F6" Foreground="White" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </TabItem>
                        </TabControl>

                        <!-- 右侧：报表中心 -->
                        <GroupBox Header="专业报表输出中心" Grid.Column="1" Padding="15" BorderBrush="#3B82F6" BorderThickness="2" FontWeight="Bold">
                            <StackPanel>
                                <Button Content="执行全场编排" Click="GenerateOrder_Click" Margin="0,0,0,15" Padding="15" Background="#22C55E" Foreground="White" FontWeight="Bold" FontSize="16"/>
                                <Separator Height="15" Background="#E2E8F0" Margin="0,0,0,15"/>
                                <Button Content="导出秩序册" Click="PrintManual_Click" Margin="0,0,0,8" Padding="10" Background="#F1F5F9"/>
                                <Button Content="导出编排一览表" Click="PrintHeatSheet_Click" Margin="0,0,0,8" Padding="10" Background="#F1F5F9"/>
                                <Button Content="导出检录表" Click="PrintCheckInSheet_Click" Margin="0,0,0,20" Padding="10" Background="#F1F5F9"/>
                                <TextBlock Text="成绩单分类打印" Margin="0,0,0,10" Foreground="#64748B" FontSize="12"/>
                                <Button Content="打印当前组次成绩" Click="PrintHeatResults_Click" Margin="0,0,0,8" Padding="10"/>
                                <Button Content="打印成绩公告" Click="PrintResultAnnouncement_Click" Margin="0,0,0,8" Padding="10"/>
                                <Button Content="打印本项目总排名" Click="PrintEventRanking_Click" Margin="0,0,0,8" Padding="10"/>
                                <Button Content="打印颁奖名单" Click="PrintAwards_Click" Margin="0,0,0,8" Padding="10"/>
                                <Button Content="打印团体总分表" Click="PrintTeamScores_Click" Margin="0,0,0,8" Padding="10"/>
                                <Button Content="打印破纪录一览" Click="PrintRecords_Click" Margin="0,0,0,8" Padding="10"/>
                                <Button Content="打印全场总成绩册" Click="PrintFullResultBook_Click" Margin="0,0,0,5" Padding="15" BorderBrush="#3B82F6" BorderThickness="1" Background="#EFF6FF"/>
                            </StackPanel>
                        </GroupBox>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ============ Tab 2: 现场计时与成绩 ============ -->
            <TabItem Header="现场计时与成绩">
                <Grid Margin="10">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>

                    <!-- 顶部工具栏 -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="项目" VerticalAlignment="Center"/><ComboBox ItemsSource="{Binding EventsList}" SelectedItem="{Binding CurrentEvent}" Width="180" Margin="5,0,15,0"/>
                        <TextBlock Text="阶段" VerticalAlignment="Center"/><ComboBox ItemsSource="{Binding StagesList}" SelectedItem="{Binding CurrentStage}" Width="80" Margin="5,0,15,0"/>
                        <TextBlock Text="组次" VerticalAlignment="Center"/><ComboBox ItemsSource="{Binding HeatsList}" SelectedItem="{Binding CurrentHeat}" Width="50" Margin="5,0"/>
                        <Button Content="上一组" Click="PrevHeat_Click" Padding="10,5" Margin="10,0,5,0" Background="#64748B" Foreground="White"/>
                        <Button Content="下一组" Click="NextHeat_Click" Padding="10,5" Margin="0,0,15,0" Background="#3B82F6" Foreground="White"/>
                        <TextBlock Text="计时模式" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        <ComboBox x:Name="TimingMode" Width="100" Margin="5,0" Padding="4"><System:String>手动计时</System:String><System:String>自动计时</System:String></ComboBox>
                        <Button Content="开始比赛" Padding="20,5" Margin="15,0" Background="#22C55E" Foreground="White" FontWeight="Bold" FontSize="14"/>
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="480"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>

                        <!-- 左侧：8泳道面板 -->
                        <GroupBox Header="泳道状态监控" Margin="0,0,10,0">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding LaneStatuses}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="5" Padding="8" BorderThickness="2" CornerRadius="8" BorderBrush="#CBD5E1" Background="#F8FAFC">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="45"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="120"/>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="60"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding LaneNumber}" FontSize="28" FontWeight="Bold" Foreground="#3B82F6" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                    <StackPanel Grid.Column="1" Margin="10,0">
                                                        <TextBlock Text="{Binding SwimmerName}" FontWeight="Bold" FontSize="14"/>
                                                        <TextBlock Text="{Binding Organization}" Foreground="#64748B" FontSize="11"/>
                                                    </StackPanel>
                                                    <TextBox Grid.Column="2" Text="{Binding TimeInput, UpdateSourceTrigger=PropertyChanged}" FontSize="18" FontWeight="Bold" Padding="5" VerticalAlignment="Center" ToolTip="输入成绩 ss.ff 或 m:ss.ff"/>
                                                    <ComboBox Grid.Column="3" SelectedItem="{Binding Status}" Margin="5,0" Padding="3" VerticalAlignment="Center">
                                                        <System:String>OK</System:String><System:String>DSQ</System:String><System:String>WDR</System:String><System:String>DNS</System:String>
                                                    </ComboBox>
                                                    <Button Grid.Column="4" Content="确认" Click="ConfirmLaneResult_Click" Tag="{Binding LaneNumber}" Padding="5,3" VerticalAlignment="Center" Background="#22C55E" Foreground="White" FontSize="11"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </GroupBox>

                        <!-- 右侧 -->
                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                            <GroupBox Header="当前组次成绩（按时间排序）">
                                <DataGrid ItemsSource="{Binding CurrentHeatResults}" AutoGenerateColumns="False" IsReadOnly="True" FontSize="13" RowHeight="32">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="名次" Binding="{Binding Rank}" Width="50">
                                            <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="FontWeight" Value="Bold"/><Setter Property="HorizontalAlignment" Value="Center"/></Style></DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="泳道" Binding="{Binding Lane}" Width="50"/>
                                        <DataGridTextColumn Header="姓名" Binding="{Binding SwimmerName}" Width="100"/>
                                        <DataGridTextColumn Header="单位" Binding="{Binding Organization}" Width="100"/>
                                        <DataGridTextColumn Header="成绩" Binding="{Binding FinishTimeDisplay}" Width="80">
                                            <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="Foreground" Value="#1E40AF"/><Setter Property="FontWeight" Value="Bold"/></Style></DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="50"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </GroupBox>
                            <GroupBox Grid.Row="1" Header="本项目实时总排名（跨组汇总）">
                                <DataGrid ItemsSource="{Binding EventRankings}" AutoGenerateColumns="False" IsReadOnly="True" Background="#F8FAFC" FontSize="13" RowHeight="30">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="名次" Binding="{Binding OverallRank}" Width="50">
                                            <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="FontWeight" Value="Bold"/><Setter Property="HorizontalAlignment" Value="Center"/></Style></DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="姓名" Binding="{Binding SwimmerName}" Width="100"/>
                                        <DataGridTextColumn Header="单位" Binding="{Binding Organization}" Width="100"/>
                                        <DataGridTextColumn Header="组次" Binding="{Binding HeatNumber}" Width="50"/>
                                        <DataGridTextColumn Header="泳道" Binding="{Binding Lane}" Width="50"/>
                                        <DataGridTextColumn Header="成绩" Binding="{Binding FinishTimeDisplay}" Width="80">
                                            <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="Foreground" Value="#1E40AF"/><Setter Property="FontWeight" Value="Bold"/></Style></DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="50"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </GroupBox>
                        </Grid>
                    </Grid>

                    <!-- 底部操作栏 -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                        <Button Content="确认本组全部成绩" Click="ConfirmAllHeatResults_Click" Padding="20,10" Background="#22C55E" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,0,15,0"/>
                        <Button Content="进入下一组" Click="NextHeat_Click" Padding="20,10" Background="#3B82F6" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,0,15,0"/>
                        <Button Content="编排决赛/半决赛" Click="ProcessPromotion_Click" Padding="20,10" Background="#F59E0B" Foreground="White" FontWeight="Bold" FontSize="14"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ============ Tab 3: 大屏显示控制 ============ -->
            <TabItem Header="大屏显示控制">
                <Grid Margin="20">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="400"/></Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,20,0">
                        <GroupBox Header="1. 比赛流程控制" Padding="15" Margin="0,0,0,20">
                            <UniformGrid Columns="2" Rows="2">
                                <Button Content="显示全场项目预告" Click="PushEventList_Click" Margin="5" Padding="10" Background="#3B82F6" Foreground="White"/>
                                <Button Content="显示本项目编排表" Click="PushHeatSheet_Click" Margin="5" Padding="10" Background="#3B82F6" Foreground="White"/>
                                <Button Content="显示当前组次出场" Click="PushCurrentHeat_Click" Margin="5" Padding="10" Background="#60A5FA" Foreground="White"/>
                                <Button Content="切换至实时计时画面" Click="PushLiveTiming_Click" Margin="5" Padding="10" Background="#22C55E" Foreground="White"/>
                            </UniformGrid>
                        </GroupBox>

                        <GroupBox Header="2. 成绩与排名推送" Padding="15" Margin="0,0,0,20">
                            <UniformGrid Columns="2" Rows="2">
                                <Button Content="显示本组成绩" Click="PushHeatResults_Click" Margin="5" Padding="10" Background="#F59E0B" Foreground="White"/>
                                <Button Content="显示本项目总排名" Click="PushEventRanking_Click" Margin="5" Padding="10" Background="#F59E0B" Foreground="White"/>
                                <Button Content="显示决赛名单" Click="PushFinalsListDisplay_Click" Margin="5" Padding="10" Background="#EF4444" Foreground="White"/>
                                <Button Content="显示颁奖榜" Click="PushMedalList_Click" Margin="5" Padding="10" Background="#EF4444" Foreground="White"/>
                            </UniformGrid>
                        </GroupBox>

                        <GroupBox Header="3. 现场礼仪与商务展示" Padding="15">
                            <UniformGrid Columns="2" Rows="2">
                                <Button Content="开始颁奖仪式" Click="PushAwardCeremony_Click" Margin="5" Padding="10" Background="#D97706" Foreground="White"/>
                                <Button Content="播放赞助商广告" Click="PushSponsorAd_Click" Margin="5" Padding="10" Background="#64748B" Foreground="White"/>
                                <Button Content="显示赛事欢迎画面" Click="PushWelcomeScreen_Click" Margin="5" Padding="10" Background="#64748B" Foreground="White"/>
                                <Button Content="显示休息中/暂停画面" Click="PushPauseScreen_Click" Margin="5" Padding="10" Background="#64748B" Foreground="White"/>
                            </UniformGrid>
                        </GroupBox>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <GroupBox Header="实时信息公告推送" Padding="15" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="公告内容:" Margin="0,0,0,5"/>
                                <TextBox x:Name="AnnouncementBox" Text="{Binding DisplayAnnouncement, UpdateSourceTrigger=PropertyChanged}" Height="120" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,10"/>
                                <Button Content="发布紧急公告至大屏" Click="PushAnnouncement_Click" Padding="10" Background="#7C3AED" Foreground="White" FontWeight="Bold"/>
                                <Button Content="清除公告显示" Click="ClearAnnouncement_Click" Margin="0,10,0,0" Padding="10"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="团体总分推送" Padding="15" Margin="0,0,0,20">
                            <Button Content="推送团体总分至大屏" Click="PushTeamScores_Click" Padding="10" Background="#8B5CF6" Foreground="White" FontWeight="Bold"/>
                        </GroupBox>

                        <GroupBox Header="大屏状态预览" Padding="15">
                            <StackPanel>
                                <TextBlock Text="当前大屏模式:" FontWeight="Bold"/>
                                <TextBlock x:Name="ScreenStatusText" Text="[待机]" Foreground="#22C55E" FontSize="18" Margin="0,5,0,15"/>
                                <TextBlock Text="翻页停留时间 (秒):" Margin="0,0,0,5"/>
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                                    <Slider Value="{Binding PageFlipInterval}" Minimum="3" Maximum="60" TickFrequency="1" IsSnapToTickEnabled="True"/>
                                    <TextBlock Grid.Column="1" Text="{Binding PageFlipInterval}" HorizontalAlignment="Right" VerticalAlignment="Center" FontWeight="Bold" Foreground="#3B82F6"/>
                                </Grid>
                                <TextBlock Text="连接中的终端数:" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding ConnectionCount}" FontSize="24" FontWeight="Bold" Foreground="#3B82F6"/>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ============ Tab 4: 系统日志与数据 ============ -->
            <TabItem Header="系统日志与数据">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="300"/></Grid.ColumnDefinitions>
                    <GroupBox Header="运行日志"><ListBox ItemsSource="{Binding SystemLogs}" FontFamily="Consolas" FontSize="12" BorderThickness="0"/></GroupBox>
                    <GroupBox Grid.Column="1" Header="存档管理" Margin="10,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                            <ListBox ItemsSource="{Binding SavedCompetitions}" SelectedItem="{Binding SelectedBackup}" Margin="0,0,0,10">
                                <ListBox.ItemTemplate><DataTemplate><StackPanel Margin="5"><TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="#1E40AF"/><TextBlock Text="{Binding LastModified}" FontSize="11" Foreground="Gray"/></StackPanel></DataTemplate></ListBox.ItemTemplate>
                            </ListBox>
                            <StackPanel Grid.Row="1">
                                <Button Content="加载选中存档" Click="LoadBackup_Click" Padding="10" Background="#22C55E" Foreground="White" Margin="0,0,0,5"/>
                                <Button Content="删除选中存档" Click="DeleteBackup_Click" Padding="10" Background="#EF4444" Foreground="White" Margin="0,0,0,10"/>
                                <Button Content="清除当前库数据" Click="ClearDatabase_Click" Padding="10" Background="#7F1D1D" Foreground="White" Margin="0,0,0,10"/>
                                <Button Content="强制保存" Click="SaveData_Click" Padding="10" Background="#3B82F6" Foreground="White" Margin="0,0,0,5"/>
                            </StackPanel>
                        </Grid>
                    </GroupBox>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- 全场报名表弹出层 -->
        <Grid x:Name="RegistrationModal" Visibility="Collapsed" Grid.Row="0" Grid.RowSpan="2" Panel.ZIndex="1000">
            <Border Background="#A0000000" MouseDown="CloseRegistrationList_Click"/>
            <Border Background="White" Width="1100" Height="700" VerticalAlignment="Center" HorizontalAlignment="Center" CornerRadius="15" BorderBrush="#3B82F6" BorderThickness="2">
                <Grid Margin="20">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="全场运动员报名总表" FontSize="24" FontWeight="Bold" Foreground="#1E293B"/>
                        <TextBlock Text="(按姓名去重)" VerticalAlignment="Bottom" Margin="10,0,0,2" Foreground="#64748B"/>
                    </StackPanel>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding DistinctSwimmers}" AutoGenerateColumns="False" HorizontalScrollBarVisibility="Auto" IsReadOnly="True" FontSize="14" RowHeight="35">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="号码" Binding="{Binding BibNumber}" Width="70"/>
                            <DataGridTextColumn Header="姓名" Binding="{Binding Name}" Width="100"/>
                            <DataGridTextColumn Header="性别" Binding="{Binding Gender}" Width="50"/>
                            <DataGridTextColumn Header="单位" Binding="{Binding Organization}" Width="120"/>
                            <DataGridTextColumn Header="年龄组" Binding="{Binding AgeGroup}" Width="80"/>
                            <DataGridTextColumn Header="出生日期" Binding="{Binding BirthDate}" Width="100"/>
                            <DataGridTextColumn Header="电话" Binding="{Binding Phone}" Width="120"/>
                            <DataGridTextColumn Header="备注" Binding="{Binding Notes}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <Button Grid.Row="2" Content="关闭报名表" Click="CloseRegistrationList_Click" HorizontalAlignment="Right" Padding="30,10" Margin="0,15,0,0" Background="#EF4444" Foreground="White" FontWeight="Bold"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
