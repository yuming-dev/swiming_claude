                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Ellipse x:Name="RaceStateIndicator" Width="12" Height="12" Fill="#F59E0B" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="RaceStateLabel" Text="等待" FontSize="14" FontWeight="Bold" Foreground="#94A3B8" VerticalAlignment="Center" Width="42" TextAlignment="Center"/>
                                    </StackPanel>
                                </Border>
