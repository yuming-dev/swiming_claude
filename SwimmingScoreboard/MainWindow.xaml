                        <TextBlock Text="组别:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <ComboBox x:Name="ResultAgeGroupCombo" Width="90" Margin="0,0,8,0" SelectionChanged="ResultAgeGroup_Changed"
                                  ToolTip="选择“全部”表示不按组别过滤"/>
                        <TextBlock Text="性别:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <ComboBox x:Name="ResultGenderCombo" Width="70" SelectionChanged="ResultGender_Changed">
                            <ComboBoxItem Content="男" IsSelected="True"/>
                            <ComboBoxItem Content="女"/>
                            <ComboBoxItem Content="混合"/>
                        </ComboBox>
                        <TextBlock Text=" 项目:" VerticalAlignment="Center" Margin="8,0,4,0"/>
                        <ComboBox x:Name="ResultEventCombo" Width="200" SelectionChanged="ResultEvent_Changed"/>
                        <TextBlock Text=" 阶段:" VerticalAlignment="Center" Margin="8,0,4,0"/>
                        <ComboBox x:Name="ResultStageCombo" Width="80" SelectionChanged="ResultStage_Changed">
                            <ComboBoxItem Content="预赛" IsSelected="True"/>
                            <ComboBoxItem Content="半决赛"/>
                            <ComboBoxItem Content="决赛"/>
                        </ComboBox>
                        <TextBlock Text=" 组:" VerticalAlignment="Center" Margin="8,0,4,0"/>
                        <ComboBox x:Name="ResultHeatCombo" Width="60" SelectionChanged="ResultHeat_Changed">
                            <ComboBoxItem Content="全部" IsSelected="True"/>
                        </ComboBox>
                        <Button Content="晋级处理" Click="Promotion_Click" Padding="12,4" Margin="16,0,0,0"
                                Background="#8B5CF6" Foreground="White" BorderThickness="0"/>
                        <Button Content="团体计���" Click="CalcTeamScore_Click" Padding="12,4" Margin="8,0,0,0"
                                Background="#22C55E" Foreground="White" BorderThickness="0"/>
                        <Button Content="查询原始数据" Click="ViewRawData_Click" Padding="12,4" Margin="8,0,0,0"
                                Background="#64748B" Foreground="White" BorderThickness="0"/>
                    </StackPanel>
                    <DataGrid x:Name="ResultGrid" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False"
                              IsReadOnly="True" AlternatingRowBackground="#F8FAFC">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="名次" Binding="{Binding Rank}" Width="50"/>
                            <DataGridTextColumn Header="道" Binding="{Binding Lane}" Width="40"/>
                            <DataGridTextColumn Header="号码" Binding="{Binding BibNumber}" Width="60"/>
                            <DataGridTextColumn Header="姓名" Binding="{Binding Name}" Width="80"/>
                            <DataGridTextColumn Header="代表队" Binding="{Binding Country}" Width="80"/>
                            <DataGridTextColumn Header="最终成绩" Binding="{Binding FinalTime}" Width="80"/>
                            <DataGridTextColumn Header="计时源" Binding="{Binding TimingSource}" Width="60"/>
                            <DataGridTextColumn Header="反应时间" Binding="{Binding ReactionTime}" Width="70"/>
                            <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="50"/>
                            <DataGridTextColumn Header="纪录" Binding="{Binding RecordNote}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ═══ 文档编辑 / 输出 / 打印 ═══ -->
            <TabItem Header="文档编辑/输出/打印">
                <TabItem.Resources>
                    <!-- 输出文档卡片中两种统一按钮：编辑 / 输出 -->
                    <Style x:Key="DocActionBtn" TargetType="Button">
                        <Setter Property="Padding" Value="14,7"/>
                        <Setter Property="Margin" Value="6,0,0,0"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="MinWidth" Value="78"/>
                        <Setter Property="Cursor" Value="Hand"/>
                    </Style>
                    <Style x:Key="DocCardBorder" TargetType="Border">
                        <Setter Property="Background" Value="#FAFBFC"/>
                        <Setter Property="BorderBrush" Value="#E2E8F0"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="CornerRadius" Value="6"/>
                        <Setter Property="Padding" Value="12"/>
                        <Setter Property="Margin" Value="6"/>
                        <Setter Property="Width" Value="300"/>
                    </Style>
                    <Style x:Key="DocTitle" TargetType="TextBlock">
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Foreground" Value="#1E293B"/>
                    </Style>
                    <Style x:Key="DocSub" TargetType="TextBlock">
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="Foreground" Value="#64748B"/>
                        <Setter Property="TextWrapping" Value="Wrap"/>
                        <Setter Property="Margin" Value="0,3,0,8"/>
                    </Style>
                </TabItem.Resources>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <!-- 标题 + 说明 -->
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="文档编辑 / 输出 / 打印" FontSize="22" FontWeight="Bold" Foreground="#1E293B"/>
                            <TextBlock Margin="0,4,0,0" FontSize="12" Foreground="#64748B" TextWrapping="Wrap"
                                       Text="所有文档支持&quot;编辑&quot;（自定义内容）与&quot;输出&quot;（在弹出窗口中预览，并可导出为 PDF / DOC / HTML 或直接打印）。"/>
                        </StackPanel>

                        <!-- ═══ 一、赛前文档 ═══ -->
                        <Border Background="White" CornerRadius="10" Padding="14" Margin="0,0,0,12"
                                BorderBrush="#E2E8F0" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="一、赛前文档" FontSize="15" FontWeight="Bold" Foreground="#3B82F6" Margin="0,0,0,8"/>
                                <WrapPanel>
                                    <Border Style="{StaticResource DocCardBorder}">
                                        <StackPanel>
                                            <TextBlock Text="秩序册" Style="{StaticResource DocTitle}"/>
                                            <TextBlock Style="{StaticResource DocSub}"
                                                       Text="封面/前言/规程/活动日程/技术官员/运动队人员等。"/>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="编辑" Click="EditProgramBook_Click" Background="#7C3AED" Style="{StaticResource DocActionBtn}"/>
                                                <Button Content="输出 / 打印" Click="PrintManual_Click" Background="#2563EB" Style="{StaticResource DocActionBtn}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource DocCardBorder}">
                                        <StackPanel>
                                            <TextBlock Text="竞赛日程" Style="{StaticResource DocTitle}"/>
                                            <TextBlock Style="{StaticResource DocSub}"
                                                       Text="按场次列出比赛日期/时间/项目编号/赛次/组数。"/>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="输出 / 打印" Click="PrintSchedule_Click" Background="#3B82F6" Style="{StaticResource DocActionBtn}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource DocCardBorder}">
                                        <StackPanel>
                                            <TextBlock Text="出发表" Style="{StaticResource DocTitle}"/>
                                            <TextBlock Style="{StaticResource DocSub}"
                                                       Text="按赛程顺序、每组出场名单（道次 / 号码 / 姓名 / 代表队 / 备注）。"/>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="输出 / 打印" Click="PrintStartList_Click" Background="#1D4ED8" Style="{StaticResource DocActionBtn}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <!-- ═══ 二、比赛成绩 ═══ -->
                        <Border Background="White" CornerRadius="10" Padding="14" Margin="0,0,0,12"
                                BorderBrush="#E2E8F0" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="二、比赛成绩" FontSize="15" FontWeight="Bold" Foreground="#059669" Margin="0,0,0,8"/>
                                <WrapPanel>
                                    <Border Style="{StaticResource DocCardBorder}">
                                        <StackPanel>
                                            <TextBlock Text="成绩册" Style="{StaticResource DocTitle}"/>
                                            <TextBlock Style="{StaticResource DocSub}"
                                                       Text="封面/奖牌榜/体育道德风尚奖/破纪录/名次公告/成绩公告。"/>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="编辑" Click="EditResultBook_Click" Background="#B45309" Style="{StaticResource DocActionBtn}"/>
                                                <Button Content="输出 / 打印" Click="PrintFullResultBook_Click" Background="#047857" Style="{StaticResource DocActionBtn}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource DocCardBorder}">
                                        <StackPanel>
                                            <TextBlock Text="分组成绩" Style="{StaticResource DocTitle}"/>
                                            <TextBlock Style="{StaticResource DocSub}"
                                                       Text="当前比赛组的完整成绩单（名次/道次/号码/姓名/成绩/反应时）。"/>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="输出 / 打印" Click="PrintHeatResults_Click" Background="#059669" Style="{StaticResource DocActionBtn}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource DocCardBorder}">
                                        <StackPanel>
                                            <TextBlock Text="项目成绩" Style="{StaticResource DocTitle}"/>
                                            <TextBlock Style="{StaticResource DocSub}"
                                                       Text="按项目汇总（决赛排名总表）。"/>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="输出 / 打印" Click="PrintEventResults_Click" Background="#10B981" Style="{StaticResource DocActionBtn}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource DocCardBorder}">
                                        <StackPanel>
                                            <TextBlock Text="分段计时报告" Style="{StaticResource DocTitle}"/>
                                            <TextBlock Style="{StaticResource DocSub}"
                                                       Text="每 50m / 100m 分段时间，含触板与盲表。"/>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="输出 / 打印" Click="PrintSplitTimeReport_Click" Background="#34D399" Style="{StaticResource DocActionBtn}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <!-- ═══ 三、排名与纪录 ═══ -->
                        <Border Background="White" CornerRadius="10" Padding="14" Margin="0,0,0,12"
                                BorderBrush="#E2E8F0" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="三、排名与纪录" FontSize="15" FontWeight="Bold" Foreground="#D97706" Margin="0,0,0,8"/>
                                <WrapPanel>
                                    <Border Style="{StaticResource DocCardBorder}">
                                        <StackPanel>
                                            <TextBlock Text="团体成绩" Style="{StaticResource DocTitle}"/>
                                            <TextBlock Style="{StaticResource DocSub}"
                                                       Text="代表队总分排名（个人分/接力分/破纪录加分/金银铜）。"/>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="输出 / 打印" Click="PrintTeamStandings_Click" Background="#D97706" Style="{StaticResource DocActionBtn}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource DocCardBorder}">
                                        <StackPanel>
                                            <TextBlock Text="纪录报告" Style="{StaticResource DocTitle}"/>
                                            <TextBlock Style="{StaticResource DocSub}"
                                                       Text="本届破纪录情况一览（项目 / 类型 / 保持者 / 成绩）。"/>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="输出 / 打印" Click="PrintRecordReport_Click" Background="#F59E0B" Style="{StaticResource DocActionBtn}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <!-- ═══ 四、证书与奖状 ═══ -->
                        <Border Background="White" CornerRadius="10" Padding="14" Margin="0,0,0,12"
                                BorderBrush="#E2E8F0" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="四、证书与奖状" FontSize="15" FontWeight="Bold" Foreground="#DC2626" Margin="0,0,0,8"/>
                                <WrapPanel>
                                    <Border Style="{StaticResource DocCardBorder}">
                                        <StackPanel>
                                            <TextBlock Text="奖状" Style="{StaticResource DocTitle}"/>
                                            <TextBlock Style="{StaticResource DocSub}"
                                                       Text="冠/亚/季军证书（自动填充姓名 / 项目 / 名次 / 成绩）。"/>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="输出 / 打印" Click="PrintAwardCertificate_Click" Background="#DC2626" Style="{StaticResource DocActionBtn}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource DocCardBorder}">
                                        <StackPanel>
                                            <TextBlock Text="纪录证书" Style="{StaticResource DocTitle}"/>
                                            <TextBlock Style="{StaticResource DocSub}"
                                                       Text="破纪录证书（自动填充破纪录运动员 / 类型 / 成绩）。"/>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="输出 / 打印" Click="PrintRecordCertificate_Click" Background="#E11D48" Style="{StaticResource DocActionBtn}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <!-- 帮助提示 -->
                        <Border Background="#EFF6FF" CornerRadius="6" Padding="12" Margin="0,0,0,4" BorderBrush="#BFDBFE" BorderThickness="1">
                            <StackPanel>
                                <TextBlock FontSize="12" FontWeight="Bold" Foreground="#1E40AF" Margin="0,0,0,4" Text="输出格式说明"/>
                                <TextBlock FontSize="12" Foreground="#475569" TextWrapping="Wrap">
                                    <Run Text="所有&quot;输出 / 打印&quot;按钮会弹出预览窗口，可在窗口内："/>
                                    <LineBreak/>
                                    <Run Text="&#x00B7; "/><Run Text="导出 PDF" FontWeight="Bold"/><Run Text=" — 在浏览器中按 Ctrl+P 选择 &quot;Microsoft Print to PDF&quot;"/>
                                    <LineBreak/>
                                    <Run Text="&#x00B7; "/><Run Text="导出 DOC" FontWeight="Bold"/><Run Text=" — 直接保存为 Word 兼容的 .doc 文件"/>
                                    <LineBreak/>
                                    <Run Text="&#x00B7; "/><Run Text="导出 HTML" FontWeight="Bold"/><Run Text=" — 保存原始 HTML 文档（可二次编辑）"/>
                                    <LineBreak/>
                                    <Run Text="&#x00B7; "/><Run Text="打印" FontWeight="Bold"/><Run Text=" — 直接调用系统打印对话框"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══ 系统日志与数据 ═══ -->
            <TabItem Header="系统日志与数据">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左侧：运行日志 -->
                    <GroupBox Header="运行日志">
                        <ListBox x:Name="SystemLogListBox" FontFamily="Consolas" FontSize="12" BorderThickness="0"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                    </GroupBox>

                    <!-- 右侧：存档管理 -->
                    <GroupBox Grid.Column="1" Header="存档管理" Margin="10,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <ListBox x:Name="BackupListBox" Margin="0,0,0,10">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="5">
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="#1E40AF"/>
                                            <TextBlock Text="{Binding LastModified}" FontSize="11" Foreground="Gray"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <StackPanel Grid.Row="1">
                                <Button Content="加载选中存档" Click="LoadBackup_Click" Padding="10" FontSize="14"
                                        Background="#22C55E" Foreground="White" BorderThickness="0" Margin="0,0,0,5"/>
                                <Button Content="删除选中存档" Click="DeleteBackup_Click" Padding="10" FontSize="14"
                                        Background="#EF4444" Foreground="White" BorderThickness="0" Margin="0,0,0,10"/>
                                <Button Content="清除当前库数据" Click="ClearDatabase_Click" Padding="10" FontSize="14"
                                        Background="#7F1D1D" Foreground="White" BorderThickness="0" Margin="0,0,0,5"/>
                                <Button Content="删除全部纪录" Click="ClearAllRecords_Click" Padding="10" FontSize="14"
                                        Background="#DC2626" Foreground="White" BorderThickness="0" Margin="0,0,0,10"/>
                                <Button Content="强制保存" Click="ForceSave_Click" Padding="10" FontSize="14"
                                        Background="#3B82F6" Foreground="White" BorderThickness="0" Margin="0,0,0,5"/>
                                <Separator Margin="0,5,0,5"/>
                                <Button Content="查询本机IP地址" Click="ShowLocalIP_Click" Padding="10" FontSize="14"
                                        Background="#0EA5E9" Foreground="White" BorderThickness="0" Margin="0,0,0,5"/>
                                <Button Content="修改密码" Click="ChangePassword_Click" Padding="10" FontSize="14"
                                        Background="#475569" Foreground="White" BorderThickness="0"/>
                            </StackPanel>
                        </Grid>
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- ═══ 设置 ═══ -->
            <TabItem Header="设置">
                <ScrollViewer Margin="10">
                    <StackPanel MaxWidth="600" HorizontalAlignment="Left">
                        <TextBlock Text="计时硬件连接" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="36"/>
                                <RowDefinition Height="36"/>
                                <RowDefinition Height="36"/>
                                <RowDefinition Height="36"/>
                                <RowDefinition Height="36"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="串口:" VerticalAlignment="Center"/>
                            <ComboBox x:Name="ComPortCombo" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center"/>
                            <Button Grid.Row="0" Grid.Column="2" Content="连接串口" Click="ConnectSerial_Click" Padding="12,4" Margin="8,0,0,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="TCP地址:" VerticalAlignment="Center"/>
                            <TextBox x:Name="TcpHostBox" Grid.Row="1" Grid.Column="1" Text="127.0.0.1:5000" Padding="4" VerticalAlignment="Center"/>
                            <Button Grid.Row="1" Grid.Column="2" Content="连接TCP" Click="ConnectTcp_Click" Padding="12,4" Margin="8,0,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="UDP收端口:" VerticalAlignment="Center"/>
                            <TextBox x:Name="UdpPortBox" Grid.Row="2" Grid.Column="1" Text="5001" Padding="4" VerticalAlignment="Center"/>
                            <Button Grid.Row="2" Grid.Column="2" Content="监听UDP" Click="ConnectUdp_Click" Padding="12,4" Margin="8,0,0,0"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="UDP发送:" VerticalAlignment="Center"/>
                            <TextBox x:Name="UdpSendBox" Grid.Row="3" Grid.Column="1" Text="127.0.0.1:5002" Padding="4" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="状态:" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TimingStatusText" Grid.Row="4" Grid.Column="1" Text="未连接" VerticalAlignment="Center" Foreground="#EF4444"/>
                            <Button Grid.Row="4" Grid.Column="2" Content="断开" Click="DisconnectTiming_Click" Padding="12,4" Margin="8,0,0,0"/>
                        </Grid>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
