<Window x:Class="SwimmingScoreboard.ResultBookEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="成绩册编辑器"
        Width="1020" Height="720"
        WindowStartupLocation="CenterOwner"
        Background="#F8FAFC">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="6"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
        </Style>
        <Style x:Key="MultiBox" TargetType="TextBox">
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontFamily" Value="Microsoft YaHei,SimSun"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="True"/>
            <Setter Property="CanUserDeleteRows" Value="True"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="RowHeight" Value="28"/>
            <Setter Property="AlternatingRowBackground" Value="#F1F5F9"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,4,18,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#B45309" Padding="16,12">
            <StackPanel>
                <TextBlock Text="成绩册编辑器" FontSize="18" FontWeight="Bold" Foreground="White"/>
                <TextBlock Foreground="#FEF3C7" Margin="0,4,0,0" FontSize="12"
                           Text="编辑封面、前言、体育道德风尚奖名单、教练员/联合培养单位等。修改后可预览、打印或导出 DOC。空字段使用系统默认内容。"/>
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#E2E8F0" Padding="14,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="预览" Click="Preview_Click" Background="#0EA5E9"/>
                <Button Content="保存并打印" Click="SavePrint_Click" Background="#22C55E"
                        ToolTip="保存自定义内容，并立即在浏览器中打开成绩册预览（可在浏览器中打印或另存为 PDF）"/>
                <Button Content="导出 DOC" Click="ExportDoc_Click" Background="#0284C7"
                        ToolTip="保存为 .doc 文件（Word 可直接打开）"/>
                <Button Content="重置为默认" Click="Reset_Click" Background="#94A3B8"/>
                <Button Content="保存" Click="Save_Click" Background="#3B82F6"/>
                <Button Content="取消" Click="Cancel_Click" Background="#EF4444"/>
            </StackPanel>
        </Border>

        <TabControl Margin="10">
            <!-- 1. 封面 / 前言 / 尾页 -->
            <TabItem Header="封面 / 前言 / 尾页">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="封面主标题:" Foreground="#475569" Grid.Row="0" Grid.Column="0" Margin="0,8" VerticalAlignment="Center"/>
                    <TextBox x:Name="CoverTitleBox" Grid.Row="0" Grid.Column="1" Margin="0,8"/>
                    <TextBlock Text="封面副标题:" Foreground="#475569" Grid.Row="1" Grid.Column="0" Margin="0,8" VerticalAlignment="Center"/>
                    <TextBox x:Name="CoverSubtitleBox" Grid.Row="1" Grid.Column="1" Margin="0,8"/>
                    <TextBlock Text="场地示意图:" Foreground="#475569" Grid.Row="2" Grid.Column="0" Margin="0,8" VerticalAlignment="Center"/>
                    <DockPanel Grid.Row="2" Grid.Column="1" Margin="0,8">
                        <Button DockPanel.Dock="Right" Content="选择..." Click="PickVenueImage_Click" Background="#3B82F6"/>
                        <Button DockPanel.Dock="Right" Content="清除" Click="ClearVenueImage_Click" Background="#94A3B8"/>
                        <TextBox x:Name="VenueImagePathBox" IsReadOnly="True" Background="#F1F5F9"/>
                    </DockPanel>
                    <TextBlock Grid.Row="3" Grid.ColumnSpan="2" Text="前言（出现在封面之后）" FontWeight="Bold" Foreground="#B45309" Margin="0,12,0,4"/>
                    <TextBox x:Name="ForewordBox" Grid.Row="4" Grid.ColumnSpan="2" Style="{StaticResource MultiBox}" MinHeight="120"/>
                    <TextBlock Grid.Row="5" Grid.ColumnSpan="2" Text="尾页 / 附注（出现在文档末尾）" FontWeight="Bold" Foreground="#B45309" Margin="0,12,0,4"/>
                    <TextBox x:Name="ClosingBox" Grid.Row="6" Grid.ColumnSpan="2" Style="{StaticResource MultiBox}" MinHeight="100"/>
                </Grid>
            </TabItem>

            <!-- 2. 体育道德风尚奖 -->
            <TabItem Header="体育道德风尚奖">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Foreground="#475569" Margin="0,0,0,10"
                               Text="每行一个名字。运动员/裁判员可写为&quot;姓名(代表队)&quot;的格式（参考国家级赛事样式）。"/>
                    <TextBlock Grid.Row="1" Text="获奖运动队（每行一个）" FontWeight="Bold" Foreground="#B45309" Margin="0,4,0,4"/>
                    <TextBox x:Name="SportsTeamsBox" Grid.Row="2" Style="{StaticResource MultiBox}" MinHeight="80"/>
                    <TextBlock Grid.Row="3" Text="获奖运动员（每行一个，建议格式：姓名(代表队)）" FontWeight="Bold" Foreground="#B45309" Margin="0,12,0,4"/>
                    <TextBox x:Name="SportsAthletesBox" Grid.Row="4" Style="{StaticResource MultiBox}" MinHeight="120"/>
                    <TextBlock Grid.Row="5" Text="获奖裁判员（每行一个）" FontWeight="Bold" Foreground="#B45309" Margin="0,12,0,4"/>
                    <TextBox x:Name="SportsJudgesBox" Grid.Row="6" Style="{StaticResource MultiBox}" MinHeight="80"/>
                </Grid>
            </TabItem>

            <!-- 3. 教练员 / 联合培养单位 -->
            <TabItem Header="教练员 / 联合培养">
                <DockPanel Margin="14">
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                        <TextBlock Foreground="#475569"
                                   Text="为名次公告（决赛排名表）中的运动员补充教练员、联合培养单位（如&quot;深圳大学&quot;）。"/>
                        <Button HorizontalAlignment="Left" Margin="0,8,0,0" Padding="14,5"
                                Content="从已注册运动员自动建表" Click="AutoFillSwimmers_Click" Background="#0EA5E9"/>
                    </StackPanel>
                    <DataGrid x:Name="SwimmerInfoGrid">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="号码" Binding="{Binding BibNumber}" Width="80"/>
                            <DataGridTextColumn Header="姓名" Binding="{Binding Name}" Width="140"/>
                            <DataGridTextColumn Header="代表队" Binding="{Binding Country}" Width="140"/>
                            <DataGridTextColumn Header="教练员" Binding="{Binding Coach}" Width="200"/>
                            <DataGridTextColumn Header="联合培养单位" Binding="{Binding JointTrainingUnit}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- 4. 显示选项 -->
            <TabItem Header="显示选项">
                <StackPanel Margin="20">
                    <TextBlock Text="选择需要包含在成绩册中的章节" FontWeight="Bold" Foreground="#B45309" FontSize="14" Margin="0,0,0,12"/>
                    <CheckBox x:Name="OptMedalCount" Content="奖牌榜统计"/>
                    <CheckBox x:Name="OptSportsAwards" Content="体育道德风尚奖"/>
                    <CheckBox x:Name="OptRecordStats" Content="破纪录统计表"/>
                    <CheckBox x:Name="OptFinalRanking" Content="名次公告（各项目决赛名次）"/>
                    <CheckBox x:Name="OptFullResults" Content="成绩公告（各赛次每组成绩）"/>

                    <TextBlock Text="成绩公告显示选项" FontWeight="Bold" Foreground="#B45309" FontSize="14" Margin="0,18,0,8"/>
                    <CheckBox x:Name="OptShowSplits" Content="显示分段成绩（50m/100m/150m）"/>
                    <CheckBox x:Name="OptShowDiff" Content="显示成绩差（与第1名差距）"/>
                </StackPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
