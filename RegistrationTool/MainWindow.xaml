<Window x:Class="RegistrationTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="运动员注册工具" Width="720" Height="700"
        WindowStartupLocation="CenterScreen" Background="#F1F5F9">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 连接栏 -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="服务器:" VerticalAlignment="Center"/>
            <TextBox x:Name="ServerBox" Grid.Column="1" Text="127.0.0.1:3002" Padding="4" VerticalAlignment="Center"/>
            <Button x:Name="ConnBtn" Grid.Column="2" Content="连接" Click="Connect_Click" Padding="16,4" Margin="8,0,0,0"
                    Background="#3B82F6" Foreground="White" BorderThickness="0"/>
            <TextBlock x:Name="StatusText" Grid.Column="3" Text="未连接" Foreground="#EF4444" VerticalAlignment="Center" Margin="12,0,0,0"/>
        </Grid>

        <TabControl Grid.Row="1">
            <!-- 个人报名 -->
            <TabItem Header="个人项目报名">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                    <StackPanel>
                        <TextBlock Text="运动员信息" FontSize="15" FontWeight="Bold" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="姓名:" VerticalAlignment="Center"/>
                            <TextBox x:Name="NameBox" Grid.Row="0" Grid.Column="1" Padding="4" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="性别:" VerticalAlignment="Center"/>
                            <ComboBox x:Name="GenderCombo" Grid.Row="0" Grid.Column="3" VerticalAlignment="Center" SelectedIndex="0">
                                <ComboBoxItem Content="男"/><ComboBoxItem Content="女"/><ComboBoxItem Content="混合"/>
                            </ComboBox>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="出生日期:" VerticalAlignment="Center"/>
                            <DatePicker x:Name="BirthDatePicker" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="身份证号:" VerticalAlignment="Center"/>
                            <TextBox x:Name="IDNumberBox" Grid.Row="1" Grid.Column="3" Padding="4" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="代表队:" VerticalAlignment="Center"/>
                            <TextBox x:Name="CountryBox" Grid.Row="2" Grid.Column="1" Padding="4" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="单位简称:" VerticalAlignment="Center"/>
                            <TextBox x:Name="CountryShortBox" Grid.Row="2" Grid.Column="3" Padding="4" VerticalAlignment="Center"
                                     ToolTip="可选，用于大屏显示"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="组别:" VerticalAlignment="Center"/>
                            <ComboBox x:Name="AgeGroupCombo" Grid.Row="3" Grid.Column="1" VerticalAlignment="Center"
                                      IsEditable="True"
                                      ToolTip="大众赛事可填甲/乙/丙组；国际/国内大赛可留空或填年龄段">
                                <ComboBoxItem Content=""/>
                                <ComboBoxItem Content="甲组"/>
                                <ComboBoxItem Content="乙组"/>
                                <ComboBoxItem Content="丙组"/>
                                <ComboBoxItem Content="丁组"/>
                                <ComboBoxItem Content="戊组"/>
                                <ComboBoxItem Content="己组"/>
                                <ComboBoxItem Content="青少年"/>
                                <ComboBoxItem Content="少年"/>
                                <ComboBoxItem Content="青年"/>
                                <ComboBoxItem Content="成年"/>
                                <ComboBoxItem Content="大师"/>
                                <ComboBoxItem Content="老年"/>
                            </ComboBox>
                            <TextBlock Grid.Row="3" Grid.Column="2" Text="联系电话:" VerticalAlignment="Center"/>
                            <TextBox x:Name="PhoneBox" Grid.Row="3" Grid.Column="3" Padding="4" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="协会注册号:" VerticalAlignment="Center"/>
                            <TextBox x:Name="CSABox" Grid.Row="4" Grid.Column="1" Padding="4" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="4" Grid.Column="2" Text="备注:" VerticalAlignment="Center"/>
                            <TextBox x:Name="NotesBox" Grid.Row="4" Grid.Column="3" Padding="4" VerticalAlignment="Center"/>
                        </Grid>

                        <TextBlock Text="参赛项目" FontSize="14" FontWeight="Bold" Margin="0,12,0,4"/>
                        <ListBox x:Name="EventListBox" Height="100" FontSize="13"/>

                        <Border Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,8,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="项目:" VerticalAlignment="Center"/>
                                <ComboBox x:Name="EventCombo" Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,0">
                                    <ComboBoxItem Content="50米自由泳"/><ComboBoxItem Content="100米自由泳"/><ComboBoxItem Content="200米自由泳"/>
                                    <ComboBoxItem Content="400米自由泳"/><ComboBoxItem Content="800米自由泳"/><ComboBoxItem Content="1500米自由泳"/>
                                    <ComboBoxItem Content="50米仰泳"/><ComboBoxItem Content="100米仰泳"/><ComboBoxItem Content="200米仰泳"/>
                                    <ComboBoxItem Content="50米蛙泳"/><ComboBoxItem Content="100米蛙泳"/><ComboBoxItem Content="200米蛙泳"/>
                                    <ComboBoxItem Content="50米蝶泳"/><ComboBoxItem Content="100米蝶泳"/><ComboBoxItem Content="200米蝶泳"/>
                                    <ComboBoxItem Content="200米个人混合泳"/><ComboBoxItem Content="400米个人混合泳"/>
                                </ComboBox>
                                <TextBlock Grid.Column="2" Text="报名成绩:" VerticalAlignment="Center"/>
                                <TextBox x:Name="EntryTimeBox" Grid.Column="3" Padding="4" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Button Grid.Column="4" Content="+ 添加参赛项目" Click="AddEvent_Click" Padding="8,4"
                                        Background="#8B5CF6" Foreground="White" BorderThickness="0" Margin="0,0,4,0"/>
                                <Button Grid.Column="5" Content="X 删除此项" Click="RemoveEvent_Click" Padding="8,4"
                                        Background="#EF4444" Foreground="White" BorderThickness="0"/>
                            </Grid>
                        </Border>

                        <Button Content="提交全部报名信息" Click="SubmitAll_Click" Padding="0,10" Margin="0,12,0,0"
                                Background="#22C55E" Foreground="White" FontSize="15" FontWeight="Bold" BorderThickness="0"/>
                        <TextBlock x:Name="RegStatusText" Text="" Foreground="#22C55E" Margin="0,8,0,0" FontWeight="Bold" TextWrapping="Wrap"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 接力报名 -->
            <TabItem Header="接力队报名">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                    <StackPanel>
                        <TextBlock Text="接力队信息" FontSize="15" FontWeight="Bold" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="队名:" VerticalAlignment="Center"/>
                            <TextBox x:Name="RelayTeamBox" Grid.Row="0" Grid.Column="1" Padding="4" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="性别:" VerticalAlignment="Center"/>
                            <ComboBox x:Name="RelayGenderCombo" Grid.Row="0" Grid.Column="3" SelectedIndex="0" VerticalAlignment="Center">
                                <ComboBoxItem Content="男"/><ComboBoxItem Content="女"/><ComboBoxItem Content="混合"/>
                            </ComboBox>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="组别:" VerticalAlignment="Center"/>
                            <ComboBox x:Name="RelayAgeGroupCombo" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" IsEditable="True">
                                <ComboBoxItem Content=""/>
                                <ComboBoxItem Content="甲组"/>
                                <ComboBoxItem Content="乙组"/>
                                <ComboBoxItem Content="丙组"/>
                                <ComboBoxItem Content="丁组"/>
                                <ComboBoxItem Content="戊组"/>
                                <ComboBoxItem Content="己组"/>
                                <ComboBoxItem Content="青少年"/>
                                <ComboBoxItem Content="少年"/>
                                <ComboBoxItem Content="青年"/>
                                <ComboBoxItem Content="成年"/>
                                <ComboBoxItem Content="大师"/>
                                <ComboBoxItem Content="老年"/>
                            </ComboBox>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="单位简称:" VerticalAlignment="Center"/>
                            <TextBox x:Name="RelayCountryShortBox" Grid.Row="1" Grid.Column="3" Padding="4" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="项目:" VerticalAlignment="Center"/>
                            <ComboBox x:Name="RelayEventCombo" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" SelectedIndex="0" VerticalAlignment="Center">
                                <ComboBoxItem Content="4x100米自由泳接力"/><ComboBoxItem Content="4x200米自由泳接力"/><ComboBoxItem Content="4x100米混合泳接力"/>
                            </ComboBox>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="报名成绩:" VerticalAlignment="Center"/>
                            <TextBox x:Name="RelayEntryTimeBox" Grid.Row="3" Grid.Column="1" Padding="4" VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock Text="棒次安排" FontSize="14" FontWeight="Bold" Margin="0,12,0,6"/>
                        <!-- 列抬头（填写提示，防止输错） -->
                        <Grid Margin="0,0,0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/><ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="棒次" FontSize="12" FontWeight="Bold" Foreground="#1E40AF"/>
                            <TextBlock Grid.Column="1" Text="姓名（与身份证一致）" FontSize="12" FontWeight="Bold" Foreground="#1E40AF" Margin="0,0,4,0"/>
                            <TextBlock Grid.Column="2" Text="身份证号（18位）" FontSize="12" FontWeight="Bold" Foreground="#1E40AF" Margin="0,0,4,0"/>
                            <TextBlock Grid.Column="3" Text="参赛号" FontSize="12" FontWeight="Bold" Foreground="#1E40AF"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/><ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="28"/><RowDefinition Height="28"/><RowDefinition Height="28"/><RowDefinition Height="28"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="第1棒" VerticalAlignment="Center" Foreground="#64748B"/>
                            <TextBox x:Name="Leg1Name" Grid.Row="0" Grid.Column="1" Padding="4" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBox x:Name="Leg1ID"   Grid.Row="0" Grid.Column="2" Padding="4" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBox x:Name="Leg1Bib"  Grid.Row="0" Grid.Column="3" Padding="4" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="1" Text="第2棒" VerticalAlignment="Center" Foreground="#64748B"/>
                            <TextBox x:Name="Leg2Name" Grid.Row="1" Grid.Column="1" Padding="4" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBox x:Name="Leg2ID"   Grid.Row="1" Grid.Column="2" Padding="4" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBox x:Name="Leg2Bib"  Grid.Row="1" Grid.Column="3" Padding="4" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="2" Text="第3棒" VerticalAlignment="Center" Foreground="#64748B"/>
                            <TextBox x:Name="Leg3Name" Grid.Row="2" Grid.Column="1" Padding="4" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBox x:Name="Leg3ID"   Grid.Row="2" Grid.Column="2" Padding="4" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBox x:Name="Leg3Bib"  Grid.Row="2" Grid.Column="3" Padding="4" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="3" Text="第4棒" VerticalAlignment="Center" Foreground="#64748B"/>
                            <TextBox x:Name="Leg4Name" Grid.Row="3" Grid.Column="1" Padding="4" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBox x:Name="Leg4ID"   Grid.Row="3" Grid.Column="2" Padding="4" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBox x:Name="Leg4Bib"  Grid.Row="3" Grid.Column="3" Padding="4" VerticalAlignment="Center"/>
                        </Grid>
                        <!-- 填写提示（琥珀色警示条） -->
                        <Border Background="#FEF3C7" BorderBrush="#F59E0B" BorderThickness="1" CornerRadius="4" Padding="8,4" Margin="0,6,0,0">
                            <TextBlock Foreground="#92400E" FontSize="11" TextWrapping="Wrap"
                                       Text="提示：姓名需与身份证一致；身份证号为 18 位数字（供检录时核对证件）；参赛号由赛事组委会分配（可留空由系统自动分配）。"/>
                        </Border>
                        <Button Content="提交接力报名" Click="RelayRegister_Click" Padding="0,10" Margin="0,12,0,0"
                                Background="#22C55E" Foreground="White" FontSize="15" FontWeight="Bold" BorderThickness="0"/>
                        <TextBlock x:Name="RelayStatusText" Text="" Foreground="#22C55E" Margin="0,8,0,0" FontWeight="Bold"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
