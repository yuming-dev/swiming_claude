<Window x:Class="SwimmingRegistrationTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:System="clr-namespace:System;assembly=mscorlib"
        Title="游泳竞赛 - 团队报名工具" Height="850" Width="1000" Background="#F1F5F9">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部：团队名 -->
        <Border Grid.Row="0" Background="#1E293B" Padding="15" CornerRadius="10" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="参赛单位:" Foreground="White" VerticalAlignment="Center" FontSize="16" FontWeight="Bold"/>
                <TextBox x:Name="TeamNameBox" Width="300" Margin="10,0" Padding="8" FontSize="16" BorderBrush="#3B82F6"/>
            </StackPanel>
        </Border>

        <!-- 报名表单 -->
        <GroupBox Grid.Row="1" Header="运动员信息录入" Padding="15" BorderBrush="#3B82F6" Margin="0,0,0,10">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <StackPanel Margin="5"><TextBlock Text="姓名" FontWeight="Bold"/><TextBox x:Name="RegName" Padding="5"/></StackPanel>
                    <StackPanel Grid.Column="1" Margin="5"><TextBlock Text="性别" FontWeight="Bold"/><ComboBox x:Name="RegGender" Padding="4"><System:String>男</System:String><System:String>女</System:String></ComboBox></StackPanel>
                    <StackPanel Grid.Column="2" Margin="5"><TextBlock Text="出生日期" FontWeight="Bold"/><DatePicker x:Name="RegBirth" Padding="3"/></StackPanel>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <StackPanel Margin="5"><TextBlock Text="年龄组" FontWeight="Bold"/><ComboBox x:Name="RegAgeGroup" Padding="4"><System:String>儿童组</System:String><System:String>少年组</System:String><System:String>青年组</System:String><System:String>公开组</System:String></ComboBox></StackPanel>
                    <StackPanel Grid.Column="1" Margin="5"><TextBlock Text="联系电话" FontWeight="Bold"/><TextBox x:Name="RegPhone" Padding="5"/></StackPanel>
                </Grid>

                <Border Background="#EFF6FF" Padding="15" CornerRadius="8" Margin="0,10,0,0" BorderBrush="#BFDBFE" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="参赛项目（最多3项，填写距离+泳姿+报名成绩）" FontWeight="Bold" Foreground="#1E40AF" Margin="0,0,0,10"/>
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="50"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                            <TextBlock Text="项目1" VerticalAlignment="Center" FontWeight="Bold"/>
                            <ComboBox Grid.Column="1" x:Name="Dist1" Padding="4" Margin="5,0"><System:String>50米</System:String><System:String>100米</System:String><System:String>200米</System:String><System:String>400米</System:String><System:String>800米</System:String><System:String>1500米</System:String></ComboBox>
                            <ComboBox Grid.Column="2" x:Name="Stroke1" Padding="4" Margin="5,0"><System:String>自由泳</System:String><System:String>蛙泳</System:String><System:String>蝶泳</System:String><System:String>仰泳</System:String><System:String>混合泳</System:String></ComboBox>
                            <TextBox Grid.Column="3" x:Name="Time1" Padding="4" Margin="5,0" ToolTip="ss.ff 或 m:ss.ff"/>
                        </Grid>
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="50"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                            <TextBlock Text="项目2" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" x:Name="Dist2" Padding="4" Margin="5,0"><System:String>50米</System:String><System:String>100米</System:String><System:String>200米</System:String><System:String>400米</System:String><System:String>800米</System:String><System:String>1500米</System:String></ComboBox>
                            <ComboBox Grid.Column="2" x:Name="Stroke2" Padding="4" Margin="5,0"><System:String>自由泳</System:String><System:String>蛙泳</System:String><System:String>蝶泳</System:String><System:String>仰泳</System:String><System:String>混合泳</System:String></ComboBox>
                            <TextBox Grid.Column="3" x:Name="Time2" Padding="4" Margin="5,0"/>
                        </Grid>
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="50"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                            <TextBlock Text="项目3" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" x:Name="Dist3" Padding="4" Margin="5,0"><System:String>50米</System:String><System:String>100米</System:String><System:String>200米</System:String><System:String>400米</System:String><System:String>800米</System:String><System:String>1500米</System:String></ComboBox>
                            <ComboBox Grid.Column="2" x:Name="Stroke3" Padding="4" Margin="5,0"><System:String>自由泳</System:String><System:String>蛙泳</System:String><System:String>蝶泳</System:String><System:String>仰泳</System:String><System:String>混合泳</System:String></ComboBox>
                            <TextBox Grid.Column="3" x:Name="Time3" Padding="4" Margin="5,0"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Button Content="添加至报名列表" Click="AddToList_Click" HorizontalAlignment="Right" Margin="0,10,0,0" Padding="25,8" Background="#3B82F6" Foreground="White" FontWeight="Bold"/>
            </StackPanel>
        </GroupBox>

        <!-- 报名列表 -->
        <DataGrid Grid.Row="2" x:Name="RegGrid" AutoGenerateColumns="False" IsReadOnly="True" RowHeight="28" FontSize="12" Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="姓名" Binding="{Binding Name}" Width="80"/>
                <DataGridTextColumn Header="性别" Binding="{Binding Gender}" Width="40"/>
                <DataGridTextColumn Header="年龄组" Binding="{Binding AgeGroup}" Width="60"/>
                <DataGridTextColumn Header="项目" Binding="{Binding EventId}" Width="160"/>
                <DataGridTextColumn Header="报名成绩" Binding="{Binding ReportedTime}" Width="100"/>
                <DataGridTextColumn Header="出生日期" Binding="{Binding BirthDate}" Width="100"/>
                <DataGridTextColumn Header="电话" Binding="{Binding Phone}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 底部操作 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="删除选中" Click="DeleteSelected_Click" Padding="15,8" Margin="0,0,10,0" Background="#EF4444" Foreground="White"/>
            <Button Content="导出CSV文件" Click="ExportCSV_Click" Padding="25,8" Background="#22C55E" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
