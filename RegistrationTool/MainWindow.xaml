<Window x:Class="RegistrationTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="运动员注册工具" Width="700" Height="700"
        WindowStartupLocation="CenterScreen" Background="#F1F5F9">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 连接栏 -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="服务器:" VerticalAlignment="Center"/>
            <TextBox x:Name="ServerBox" Grid.Column="1" Text="127.0.0.1:3002" Padding="4" VerticalAlignment="Center"/>
            <Button x:Name="ConnBtn" Grid.Column="2" Content="连接" Click="Connect_Click" Padding="16,4" Margin="8,0,0,0"
                    Background="#3B82F6" Foreground="White" BorderThickness="0"/>
            <TextBlock x:Name="StatusText" Grid.Column="3" Text="未连接" Foreground="#EF4444" VerticalAlignment="Center" Margin="12,0,0,0"/>
        </Grid>

        <!-- 标签页 -->
        <TabControl Grid.Row="2">
            <!-- 个人报名 -->
            <TabItem Header="个人项目报名">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                    <StackPanel>
                        <TextBlock Text="运动员信息" FontSize="15" FontWeight="Bold" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="参赛号:" VerticalAlignment="Center"/>
                            <TextBox x:Name="BibBox" Grid.Row="0" Grid.Column="1" IsReadOnly="True" Background="#E2E8F0" Padding="4" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="姓名:" VerticalAlignment="Center"/>
                            <TextBox x:Name="NameBox" Grid.Row="0" Grid.Column="3" Padding="4" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="性别:" VerticalAlignment="Center"/>
                            <ComboBox x:Name="GenderCombo" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" SelectedIndex="0">
                                <ComboBoxItem Content="男"/>
                                <ComboBoxItem Content="女"/>
                            </ComboBox>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="出生日期:" VerticalAlignment="Center"/>
                            <DatePicker x:Name="BirthDatePicker" Grid.Row="1" Grid.Column="3" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="身份证号:" VerticalAlignment="Center"/>
                            <TextBox x:Name="IDNumberBox" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" Padding="4" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="代表队:" VerticalAlignment="Center"/>
                            <TextBox x:Name="CountryBox" Grid.Row="3" Grid.Column="1" Padding="4" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="3" Grid.Column="2" Text="联系电话:" VerticalAlignment="Center"/>
                            <TextBox x:Name="PhoneBox" Grid.Row="3" Grid.Column="3" Padding="4" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="项目:" VerticalAlignment="Center"/>
                            <ComboBox x:Name="EventCombo" Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="3" VerticalAlignment="Center">
                                <ComboBoxItem Content="50米自由泳"/><ComboBoxItem Content="100米自由泳"/><ComboBoxItem Content="200米自由泳"/>
                                <ComboBoxItem Content="400米自由泳"/><ComboBoxItem Content="800米自由泳"/><ComboBoxItem Content="1500米自由泳"/>
                                <ComboBoxItem Content="50米仰泳"/><ComboBoxItem Content="100米仰泳"/><ComboBoxItem Content="200米仰泳"/>
                                <ComboBoxItem Content="50米蛙泳"/><ComboBoxItem Content="100米蛙泳"/><ComboBoxItem Content="200米蛙泳"/>
                                <ComboBoxItem Content="50米蝶泳"/><ComboBoxItem Content="100米蝶泳"/><ComboBoxItem Content="200米蝶泳"/>
                                <ComboBoxItem Content="200米个人混合泳"/><ComboBoxItem Content="400米个人混合泳"/>
                            </ComboBox>
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="报名成绩:" VerticalAlignment="Center"/>
                            <TextBox x:Name="EntryTimeBox" Grid.Row="5" Grid.Column="1" Padding="4" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="5" Grid.Column="2" Text="协会注册号:" VerticalAlignment="Center"/>
                            <TextBox x:Name="CSABox" Grid.Row="5" Grid.Column="3" Padding="4" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="备注:" VerticalAlignment="Center"/>
                            <TextBox x:Name="NotesBox" Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="3" Padding="4" VerticalAlignment="Center"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                            <Button Content="注册此项目" Click="Register_Click" Padding="20,8"
                                    Background="#3B82F6" Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="0,0,8,0"/>
                            <Button Content="为同一运动员增报项目" Click="AddEvent_Click" Padding="20,8"
                                    Background="#8B5CF6" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
                        </StackPanel>
                        <TextBlock x:Name="RegStatusText" Text="" Foreground="#22C55E" Margin="0,8,0,0" FontWeight="Bold"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 接力报名 -->
            <TabItem Header="接力队报名">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                    <StackPanel>
                        <TextBlock Text="接力队信息" FontSize="15" FontWeight="Bold" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="队名:" VerticalAlignment="Center"/>
                            <TextBox x:Name="RelayTeamBox" Grid.Row="0" Grid.Column="1" Padding="4" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="性别:" VerticalAlignment="Center"/>
                            <ComboBox x:Name="RelayGenderCombo" Grid.Row="0" Grid.Column="3" VerticalAlignment="Center" SelectedIndex="0">
                                <ComboBoxItem Content="男"/><ComboBoxItem Content="女"/><ComboBoxItem Content="混合"/>
                            </ComboBox>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="项目:" VerticalAlignment="Center"/>
                            <ComboBox x:Name="RelayEventCombo" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" VerticalAlignment="Center" SelectedIndex="0">
                                <ComboBoxItem Content="4x100米自由泳接力"/><ComboBoxItem Content="4x200米自由泳接力"/><ComboBoxItem Content="4x100米混合泳接力"/>
                            </ComboBox>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="报名成绩:" VerticalAlignment="Center"/>
                            <TextBox x:Name="RelayEntryTimeBox" Grid.Row="2" Grid.Column="1" Padding="4" VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock Text="棒次安排" FontSize="14" FontWeight="Bold" Margin="0,12,0,6"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="第1棒" VerticalAlignment="Center" Foreground="#64748B"/>
                            <TextBox x:Name="Leg1Name" Grid.Row="0" Grid.Column="1" Padding="4" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBox x:Name="Leg1Bib" Grid.Row="0" Grid.Column="2" Padding="4" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="1" Text="第2棒" VerticalAlignment="Center" Foreground="#64748B"/>
                            <TextBox x:Name="Leg2Name" Grid.Row="1" Grid.Column="1" Padding="4" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBox x:Name="Leg2Bib" Grid.Row="1" Grid.Column="2" Padding="4" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="2" Text="第3棒" VerticalAlignment="Center" Foreground="#64748B"/>
                            <TextBox x:Name="Leg3Name" Grid.Row="2" Grid.Column="1" Padding="4" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBox x:Name="Leg3Bib" Grid.Row="2" Grid.Column="2" Padding="4" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="3" Text="第4棒" VerticalAlignment="Center" Foreground="#64748B"/>
                            <TextBox x:Name="Leg4Name" Grid.Row="3" Grid.Column="1" Padding="4" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBox x:Name="Leg4Bib" Grid.Row="3" Grid.Column="2" Padding="4" VerticalAlignment="Center"/>
                        </Grid>
                        <Button Content="提交接力报名" Click="RelayRegister_Click" Padding="20,8" Margin="0,12,0,0"
                                Background="#22C55E" Foreground="White" FontWeight="Bold" BorderThickness="0" HorizontalAlignment="Right"/>
                        <TextBlock x:Name="RelayStatusText" Text="" Foreground="#22C55E" Margin="0,8,0,0" FontWeight="Bold"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
