<Window x:Class="RemoteDisplayControl.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="游泳赛事管理系统 — 显示控制" Width="400" Height="500"
        WindowStartupLocation="CenterScreen" Background="#1E293B">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="远程显示控制" FontSize="18" FontWeight="Bold" Foreground="White"
                       VerticalAlignment="Center"/>
            <Button Grid.Column="1" Content="修改用户名和密码" Click="ChangePassword_Click"
                    Padding="8,2" Background="#334155" Foreground="White" BorderThickness="0" FontSize="11"/>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="地址:" Foreground="#CBD5E1" VerticalAlignment="Center"/>
            <TextBox x:Name="AddressBox" Grid.Column="1" Text="127.0.0.1:3002" Padding="6,4"
                     Background="#334155" Foreground="White" BorderBrush="#475569"/>
            <Button x:Name="ConnectBtn" Grid.Column="2" Content="连接" Click="Connect_Click"
                    Padding="12,4" Margin="8,0,0,0" Background="#3B82F6" Foreground="White" BorderThickness="0"/>
        </Grid>

        <WrapPanel Grid.Row="2">
            <Button Content="比赛视图" Click="SendMode_Click" Tag="SHOW_LIVE_RACE" Width="100" Height="40" Margin="4" Background="#22C55E" Foreground="White" BorderThickness="0"/>
            <Button Content="出发表" Click="SendMode_Click" Tag="SHOW_START_LIST" Width="100" Height="40" Margin="4" Background="#3B82F6" Foreground="White" BorderThickness="0"/>
            <Button Content="组成绩" Click="SendMode_Click" Tag="SHOW_HEAT_RESULT" Width="100" Height="40" Margin="4" Background="#8B5CF6" Foreground="White" BorderThickness="0"/>
            <Button Content="总排名" Click="SendMode_Click" Tag="SHOW_EVENT_RANKING" Width="100" Height="40" Margin="4" Background="#F59E0B" Foreground="White" BorderThickness="0"/>
            <Button Content="团体积分" Click="SendMode_Click" Tag="SHOW_TEAM_STANDINGS" Width="100" Height="40" Margin="4" Background="#06B6D4" Foreground="White" BorderThickness="0"/>
            <Button Content="颁奖典礼" Click="SendMode_Click" Tag="SHOW_AWARDS" Width="100" Height="40" Margin="4" Background="#EC4899" Foreground="White" BorderThickness="0"/>
            <Button Content="纪录榜" Click="SendMode_Click" Tag="SHOW_RECORDS" Width="100" Height="40" Margin="4" Background="#EF4444" Foreground="White" BorderThickness="0"/>
            <Button Content="欢迎画面" Click="SendMode_Click" Tag="SHOW_WELCOME" Width="100" Height="40" Margin="4" Background="#64748B" Foreground="White" BorderThickness="0"/>
            <Button Content="暂停" Click="SendMode_Click" Tag="SHOW_PAUSE" Width="100" Height="40" Margin="4" Background="#475569" Foreground="White" BorderThickness="0"/>
        </WrapPanel>

        <TextBlock x:Name="StatusText" Grid.Row="3" Text="未连接" Foreground="#EF4444"
                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
    </Grid>
</Window>
