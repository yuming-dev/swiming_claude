<Window x:Class="RemoteTimingControl.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="远程计时控制" Width="1200" Height="750"
        WindowState="Maximized" Background="#0F172A"
        KeyDown="Window_KeyDown" Closing="Window_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>

        <!-- 区域1: 导航栏 -->
        <Border Grid.Row="0" Background="#1E293B" BorderBrush="#334155" BorderThickness="0,0,0,1">
            <Grid Margin="8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="CurrentInfoText" Grid.Column="0" Text="未选择比赛" Foreground="White" FontWeight="Bold" FontSize="12" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <Button Content="◀上一组" Grid.Column="1" Click="PrevHeat_Click" Padding="8,2" Margin="0,0,4,0"
                        Background="#475569" Foreground="White" BorderThickness="0"/>
                <Button Content="下一组▶" Grid.Column="2" Click="NextHeat_Click" Padding="8,2"
                        Background="#475569" Foreground="White" BorderThickness="0"/>
                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="服务器:" Foreground="#94A3B8" Margin="0,0,4,0"/>
                    <TextBox x:Name="ServerBox" Text="127.0.0.1:3002" Width="130" Padding="2" Background="#334155" Foreground="White" BorderBrush="#475569"/>
                    <Button x:Name="ConnBtn" Content="连接" Click="Connect_Click" Padding="8,2" Margin="4,0,0,0"
                            Background="#3B82F6" Foreground="White" BorderThickness="0"/>
                </StackPanel>
                <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                    <Ellipse x:Name="StateIndicator" Width="10" Height="10" Fill="#F59E0B" Margin="0,0,4,0"/>
                    <TextBlock x:Name="StateLabel" Text="等待" Foreground="#94A3B8" FontSize="12"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 主体区域 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="190"/>
            </Grid.ColumnDefinitions>

            <!-- 赛程树（左侧） -->
            <Border Grid.Column="0" Background="#1E293B" BorderBrush="#334155" BorderThickness="0,0,1,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="赛程导航" Foreground="#64748B" FontSize="11" FontWeight="Bold" Margin="8,6,8,4"/>
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,6">
                        <Button Content="◀上一组" Click="PrevHeat_Click" Padding="6,2" Margin="0,0,4,0" FontSize="10"
                                Background="#475569" Foreground="White" BorderThickness="0"/>
                        <Button Content="下一组▶" Click="NextHeat_Click" Padding="6,2" FontSize="10"
                                Background="#475569" Foreground="White" BorderThickness="0"/>
                    </StackPanel>
                    <TreeView x:Name="ScheduleTree" Background="#1E293B" Foreground="White" FontSize="11"
                              BorderThickness="0" SelectedItemChanged="ScheduleTree_Selected"/>
                </DockPanel>
            </Border>

            <!-- 发令控制 -->
            <Border Grid.Column="1" Background="#1E293B" Padding="8" BorderBrush="#334155" BorderThickness="0,0,1,0">
                <StackPanel>
                    <TextBlock x:Name="RunningTime" Text="0.0" FontSize="30" FontWeight="Bold"
                               Foreground="#F59E0B" HorizontalAlignment="Center" FontFamily="Consolas" Margin="0,8,0,12"/>
                    <Button Content="就  位" Click="Ready_Click" Padding="0,10" FontSize="14" FontWeight="Bold"
                            Background="#F59E0B" Foreground="#000" BorderThickness="0" Margin="0,0,0,6"/>
                    <Button Content="发  令" Click="Start_Click" Padding="0,10" FontSize="14" FontWeight="Bold"
                            Background="#22C55E" Foreground="White" BorderThickness="0" Margin="0,0,0,6"/>
                    <Button Content="重新出发" Click="Restart_Click" Padding="0,10" FontSize="14" FontWeight="Bold"
                            Background="#EF4444" Foreground="White" BorderThickness="0" Margin="0,0,0,12"/>
                    <TextBlock x:Name="FalseStartInfo" Text="" Foreground="#EF4444" FontSize="11"
                               TextWrapping="Wrap" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- 区域3: 泳池图 -->
            <Border Grid.Column="2" Padding="6">
                <DockPanel>
                    <!-- 表头 -->
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="290"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="[T] 盲表 出发台 触板" Foreground="#64748B" FontSize="9" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="泳道" Foreground="#64748B" FontSize="9" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="触板 出发台 盲表 [T]" Foreground="#64748B" FontSize="9" HorizontalAlignment="Center"/>
                        <StackPanel Grid.Column="3" Orientation="Horizontal">
                            <TextBlock Text="反应" Foreground="#64748B" FontSize="9" Width="50" TextAlignment="Center"/>
                            <TextBlock Text="成绩" Foreground="#64748B" FontSize="9" Width="70" TextAlignment="Center"/>
                            <TextBlock Text="分段" Foreground="#64748B" FontSize="9" Width="60" TextAlignment="Center"/>
                            <TextBlock Text="名次" Foreground="#64748B" FontSize="9" Width="40" TextAlignment="Center"/>
                            <TextBlock Text="状态" Foreground="#64748B" FontSize="9" Width="40" TextAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="LanePanel"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- 区域4: 设置 -->
            <Border Grid.Column="3" Background="#1E293B" Padding="8" BorderBrush="#334155" BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="泳道参数" Foreground="#64748B" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="24"/>
                                <RowDefinition Height="24"/>
                                <RowDefinition Height="24"/>
                                <RowDefinition Height="24"/>
                                <RowDefinition Height="24"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="关闭时间(s)" Foreground="#94A3B8" FontSize="10" VerticalAlignment="Center"/>
                            <TextBox x:Name="SetCloseTime" Grid.Row="0" Grid.Column="1" Text="20" Padding="2" Background="#334155" Foreground="White" BorderBrush="#475569" FontSize="10"/>
                            <TextBlock Grid.Row="1" Text="出发台延迟(s)" Foreground="#94A3B8" FontSize="10" VerticalAlignment="Center"/>
                            <TextBox x:Name="SetSBDelay" Grid.Row="1" Grid.Column="1" Text="3" Padding="2" Background="#334155" Foreground="White" BorderBrush="#475569" FontSize="10"/>
                            <TextBlock Grid.Row="2" Text="确认延迟(s)" Foreground="#94A3B8" FontSize="10" VerticalAlignment="Center"/>
                            <TextBox x:Name="SetConfDelay" Grid.Row="2" Grid.Column="1" Text="3" Padding="2" Background="#334155" Foreground="White" BorderBrush="#475569" FontSize="10"/>
                            <TextBlock Grid.Row="3" Text="抢跳阈值(s)" Foreground="#94A3B8" FontSize="10" VerticalAlignment="Center"/>
                            <TextBox x:Name="SetFSThresh" Grid.Row="3" Grid.Column="1" Text="0.10" Padding="2" Background="#334155" Foreground="White" BorderBrush="#475569" FontSize="10"/>
                            <TextBlock Grid.Row="4" Text="分段显示(s)" Foreground="#94A3B8" FontSize="10" VerticalAlignment="Center"/>
                            <TextBox x:Name="SetSplitDisp" Grid.Row="4" Grid.Column="1" Text="5" Padding="2" Background="#334155" Foreground="White" BorderBrush="#475569" FontSize="10"/>
                        </Grid>
                        <Button Content="全部打开" Click="OpenAll_Click" Padding="0,6" Margin="0,8,0,2"
                                Background="#22C55E" Foreground="White" BorderThickness="0" FontSize="11"/>
                        <Button Content="全部关闭" Click="CloseAll_Click" Padding="0,6" Margin="0,0,0,8"
                                Background="#64748B" Foreground="White" BorderThickness="0" FontSize="11"/>
                        <Button Content="确认本组成绩" Click="Confirm_Click" Padding="0,8"
                                Background="#3B82F6" Foreground="White" BorderThickness="0" FontSize="12" FontWeight="Bold"/>

                        <TextBlock Text="计时源对比" Foreground="#64748B" FontSize="11" FontWeight="Bold" Margin="0,12,0,4"/>
                        <TextBlock x:Name="TimingSourceInfo" Text="" Foreground="#94A3B8" FontSize="10" TextWrapping="Wrap"/>

                        <TextBlock Text="本地串口(可选)" Foreground="#64748B" FontSize="11" FontWeight="Bold" Margin="0,12,0,4"/>
                        <ComboBox x:Name="ComPortCombo" Margin="0,0,0,4" Background="#334155" Foreground="White"/>
                        <Button Content="连接串口" Click="ConnectSerial_Click" Padding="0,4"
                                Background="#8B5CF6" Foreground="White" BorderThickness="0" FontSize="10"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- 区域5: 底部 -->
        <Border Grid.Row="2" Background="#1E293B" BorderBrush="#334155" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="180"/>
                </Grid.ColumnDefinitions>
                <DockPanel Grid.Column="0" Margin="8,4">
                    <TextBlock DockPanel.Dock="Top" Text="出发表" Foreground="#64748B" FontSize="10" Margin="0,0,0,2"/>
                    <TextBlock x:Name="StartListText" Text="" Foreground="#94A3B8" FontSize="10" TextWrapping="Wrap"/>
                </DockPanel>
                <DockPanel Grid.Column="1" Margin="8,4">
                    <TextBlock DockPanel.Dock="Top" Text="日志" Foreground="#64748B" FontSize="10" Margin="0,0,0,2"/>
                    <ListBox x:Name="LogList" FontSize="10" Foreground="#94A3B8" Background="Transparent"
                             BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                </DockPanel>
                <StackPanel Grid.Column="2" Margin="8,4">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="WsConn" Width="8" Height="8" Fill="#EF4444" Margin="0,0,4,0"/>
                        <TextBlock x:Name="WsConnText" Text="服务器: 未连接" Foreground="#94A3B8" FontSize="10"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <Ellipse x:Name="HwConn" Width="8" Height="8" Fill="#EF4444" Margin="0,0,4,0"/>
                        <TextBlock x:Name="HwConnText" Text="硬件: 未连接" Foreground="#94A3B8" FontSize="10"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
