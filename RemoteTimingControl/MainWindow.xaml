<Window x:Class="RemoteTimingControl.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="远程计时控制台" Width="1400" Height="800"
        WindowState="Maximized" Background="#0F172A"
        KeyDown="Window_KeyDown" Closing="Window_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 区域1: 导航栏 -->
        <Border Grid.Row="0" Background="#1E293B" BorderBrush="#334155" BorderThickness="0,0,0,1">
            <Grid Margin="8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="CurrentInfoText" Grid.Column="0" Text="未选择比赛" Foreground="White" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="StateIndicator" Width="10" Height="10" Fill="#F59E0B" Margin="0,0,4,0"/>
                    <TextBlock x:Name="StateLabel" Text="等待" Foreground="#94A3B8" FontSize="12"/>
                </StackPanel>
                <!-- 硬件状态+控制模式 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <Ellipse x:Name="HwConn" Width="8" Height="8" Fill="#EF4444" Margin="0,0,3,0"/>
                    <TextBlock x:Name="HwConnText" Text="硬件" Foreground="#94A3B8" FontSize="11"/>
                    <TextBlock x:Name="ControlModeText" Text="" Foreground="#64748B" FontSize="11" Margin="10,0,0,0"/>
                </StackPanel>
                <!-- 服务器连接 -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                    <Ellipse x:Name="WsConn" Width="8" Height="8" Fill="#EF4444" Margin="0,0,3,0"/>
                    <TextBlock Text="服务器" Foreground="#94A3B8" FontSize="11" Margin="0,0,4,0"/>
                    <TextBox x:Name="ServerBox" Text="127.0.0.1:3002" Width="120" Padding="2" Background="#334155" Foreground="White" BorderBrush="#475569" FontSize="11"/>
                    <Button x:Name="ConnBtn" Content="连接" Click="Connect_Click" Padding="8,2" Margin="4,0,0,0"
                            Background="#3B82F6" Foreground="White" BorderThickness="0" FontSize="11"/>
                </StackPanel>
                <!-- 参数设置 -->
                <Button Content="&#9881; 参数设置" Grid.Column="4" Click="OpenSettings_Click" Padding="8,2" Margin="8,0,0,0"
                        Background="#475569" Foreground="White" BorderThickness="0" FontSize="12"/>
                <TextBlock x:Name="WsConnText" Visibility="Collapsed"/>
            </Grid>
        </Border>

        <!-- 主体区域 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：赛程导航(6) + 计时源对比(4)，与主服务器比例一致 -->
            <Border Grid.Column="0" Background="#1E293B" BorderBrush="#334155" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="6*"/>
                        <RowDefinition Height="4*"/>
                    </Grid.RowDefinitions>

                    <!-- 赛程导航 -->
                    <DockPanel Grid.Row="0">
                        <Border DockPanel.Dock="Top" Background="#172033" Padding="10,8">
                            <TextBlock Text="赛程导航" Foreground="#3B82F6" FontSize="14" FontWeight="Bold"/>
                        </Border>
                        <TreeView x:Name="ScheduleTree" Background="#1E293B" Foreground="White" FontSize="13"
                                  BorderThickness="0" SelectedItemChanged="ScheduleTree_Selected" Margin="4,4,4,4"/>
                    </DockPanel>

                    <!-- 计时源对比（从右栏下方移过来） -->
                    <Border Grid.Row="1" BorderBrush="#334155" BorderThickness="0,1,0,0" Background="#1E293B">
                        <DockPanel Margin="10,8">
                            <TextBlock DockPanel.Dock="Top" Text="计时源对比" Foreground="#3B82F6" FontSize="13" FontWeight="Bold" Margin="0,0,0,6"/>
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="分段:" Foreground="#94A3B8" FontSize="12" VerticalAlignment="Center"/>
                                <ComboBox x:Name="SplitSelectCombo" Width="110" FontSize="12" Margin="6,0,0,0"
                                          BorderBrush="#475569" SelectionChanged="SplitSelect_Changed" SelectedIndex="0">
                                    <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">终点</sys:String>
                                </ComboBox>
                            </StackPanel>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <TextBlock x:Name="TimingSourceInfo" Text="点击泳道行查看计时源" Foreground="#94A3B8" FontSize="13" TextWrapping="Wrap"/>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- 中间：WR/CR + 滚动时间 + 泳道实时状态 + 日志 -->
            <Border Grid.Column="1" Padding="10,4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="36"/>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 顶部：WR/CR + 滚动时间 -->
                    <Grid Grid.Row="0" Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="280"/>
                            <ColumnDefinition Width="160"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="RecordDisplay" Grid.Column="1" Text="WR: ---    CR: ---"
                                   FontSize="18" FontWeight="Bold" Foreground="#F59E0B" FontFamily="Consolas"
                                   Opacity="0.9" TextAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="RunningTime" Grid.Column="2" Text="0.00"
                                   FontSize="32" FontWeight="Bold" Foreground="#F59E0B" FontFamily="Consolas"
                                   Opacity="0.85" TextAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- 表头 -->
                    <Grid x:Name="PoolHeader" Grid.Row="1" Margin="0,0,0,4"/>

                    <!-- 泳道行：固定高度，刚好容纳10道（每道60px×10 = 600px），位置固定不随窗口滚动 -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Height="620">
                        <StackPanel x:Name="LanePanel"/>
                    </ScrollViewer>

                    <!-- 日志区（填充剩余空间） -->
                    <Border Grid.Row="3" Margin="0,8,0,0" Background="#1E293B"
                            BorderBrush="#334155" BorderThickness="1" CornerRadius="4">
                        <DockPanel>
                            <Border DockPanel.Dock="Top" Background="#172033" Padding="10,6">
                                <TextBlock Text="日志" Foreground="#3B82F6" FontSize="13" FontWeight="Bold"/>
                            </Border>
                            <ListBox x:Name="LogList" FontSize="12" Foreground="#94A3B8" Background="Transparent"
                                     BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto" Margin="4"/>
                        </DockPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- 右侧操作面板 -->
            <Border Grid.Column="2" Background="#1E293B" BorderBrush="#334155" BorderThickness="1,0,0,0">
                <Border.Resources>
                    <!-- 所有按钮统一悬停/按下反馈 -->
                    <Style TargetType="Button">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Resources>
                <DockPanel Margin="10">
                    <!-- 上半部分：固定不滚动 -->
                    <StackPanel DockPanel.Dock="Top">
                        <!-- ═══ 比赛控制 ═══ -->
                        <TextBlock Text="比赛控制" Foreground="#3B82F6" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
                        <!-- 就  位 -->
                        <Button Click="Ready_Click" Height="36" Margin="0,0,0,6">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="#F59E0B" CornerRadius="8">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="&#xE7C1;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="就  位" FontSize="15" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <!-- 发  令 -->
                        <Button Click="Start_Click" Height="36" Margin="0,0,0,6">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="#22C55E" CornerRadius="8">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="发  令" FontSize="15" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <!-- 计时复位 -->
                        <Button Click="TimerReset_Click" Height="36" Margin="0,0,0,6">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="#EF4444" CornerRadius="8">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="计时复位" FontSize="15" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <!-- 确认本组成绩 -->
                        <Button Click="Confirm_Click" Height="36" Margin="0,0,0,12">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="#3B82F6" CornerRadius="8">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="确认本组成绩" FontSize="15" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- ═══ 泳道操作 ═══ -->
                        <Border BorderBrush="#334155" BorderThickness="0,1,0,0" Padding="0,10,0,0" Margin="0,0,0,6">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="泳道操作" Foreground="#3B82F6" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBox x:Name="LaneInput" Text="4" Width="46" Padding="4" FontSize="14" TextAlignment="Center"
                                             Background="#0F172A" Foreground="White" BorderBrush="#475569"/>
                                    <TextBlock Text="道" Foreground="#94A3B8" FontSize="12" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                </StackPanel>
                                <Grid Margin="0,0,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Button Grid.Row="0" Grid.Column="0" Click="MarkDNS_Click" Height="36" Margin="0,0,3,6">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="#64748B" CornerRadius="6">
                                                    <TextBlock Text="DNS" FontSize="14" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button Grid.Row="0" Grid.Column="1" Click="MarkDNF_Click" Height="36" Margin="3,0,0,6">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="#78716C" CornerRadius="6">
                                                    <TextBlock Text="DNF" FontSize="14" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button Grid.Row="1" Grid.Column="0" Click="MarkDSQ_Click" Height="36" Margin="0,0,3,6">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="#9CA3AF" CornerRadius="6">
                                                    <TextBlock Text="DSQ" FontSize="14" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button Grid.Row="1" Grid.Column="1" Click="ManualTime_Click" Height="36" Margin="3,0,0,6">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="#D97706" CornerRadius="6">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <TextBlock Text="&#xE932;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="White" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                        <TextBlock Text="手动输入" FontSize="14" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <!-- 全部打开 / 全部关闭 -->
                                    <Button Grid.Row="2" Grid.Column="0" Click="OpenAll_Click" Height="36" Margin="0,0,3,0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="#22C55E" CornerRadius="6">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <TextBlock Text="&#xE8FB;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="White" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                        <TextBlock Text="全部打开" FontSize="14" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button Grid.Row="2" Grid.Column="1" Click="CloseAll_Click" Height="36" Margin="3,0,0,0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="#64748B" CornerRadius="6">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="White" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                        <TextBlock Text="全部关闭" FontSize="14" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ═══ 显示控制 ═══ -->
                        <Border BorderBrush="#334155" BorderThickness="0,1,0,0" Padding="0,10,0,0" Margin="0,6,0,6">
                            <StackPanel>
                                <TextBlock Text="显示控制" Foreground="#3B82F6" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Button Grid.Row="0" Grid.Column="0" Tag="SHOW_START_LIST" Click="DisplayBtn_Click" Height="36" Margin="0,0,3,6">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="#3B82F6" CornerRadius="6">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                        <TextBlock Text="出发表" FontSize="14" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button Grid.Row="0" Grid.Column="1" Tag="SHOW_LIVE_RACE" Click="DisplayBtn_Click" Height="36" Margin="3,0,0,6">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="#2563EB" CornerRadius="6">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                        <TextBlock Text="比赛视图" FontSize="14" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button Grid.Row="1" Grid.Column="0" Tag="SHOW_HEAT_RESULT" Click="DisplayBtn_Click" Height="36" Margin="0,0,3,6">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="#059669" CornerRadius="6">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <TextBlock Text="&#xE9D5;" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                        <TextBlock Text="组成绩" FontSize="14" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button Grid.Row="1" Grid.Column="1" Tag="SHOW_EVENT_RANKING" Click="DisplayBtn_Click" Height="36" Margin="3,0,0,6">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="#10B981" CornerRadius="6">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <TextBlock Text="&#xE8CB;" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                        <TextBlock Text="总排名" FontSize="14" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button Grid.Row="2" Grid.Column="0" Tag="SHOW_TEAM_STANDINGS" Click="DisplayBtn_Click" Height="36" Margin="0,0,3,6">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="#D97706" CornerRadius="6">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <TextBlock Text="&#xE8D1;" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                        <TextBlock Text="团  体" FontSize="14" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button Grid.Row="2" Grid.Column="1" Tag="SHOW_AWARDS" Click="DisplayBtn_Click" Height="36" Margin="3,0,0,6">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="#F59E0B" CornerRadius="6">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <TextBlock Text="&#xE8A0;" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                        <TextBlock Text="颁  奖" FontSize="14" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button Grid.Row="3" Grid.Column="0" Tag="SHOW_RECORDS" Click="DisplayBtn_Click" Height="36" Margin="0,0,3,0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="#DC2626" CornerRadius="6">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <TextBlock Text="&#xEDB3;" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                        <TextBlock Text="纪  录" FontSize="14" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button Grid.Row="3" Grid.Column="1" Tag="SHOW_WELCOME" Click="DisplayBtn_Click" Height="36" Margin="3,0,0,0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="#8B5CF6" CornerRadius="6">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                        <TextBlock Text="欢  迎" FontSize="14" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                                <Button Click="PublishResult_Click" Height="36" Margin="0,6,0,0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="#F59E0B" CornerRadius="6">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                    <TextBlock Text="成绩发布" FontSize="14" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- 抢跳信息 -->
                        <TextBlock x:Name="FalseStartInfo" Text="" Foreground="#EF4444" FontSize="12"
                                   TextWrapping="Wrap" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>

        <TextBlock x:Name="StartListText" Visibility="Collapsed"/>
    </Grid>
</Window>
