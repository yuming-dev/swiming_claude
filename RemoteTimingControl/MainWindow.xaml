<Window x:Class="RemoteTimingControl.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="远程计时控制台" Width="1400" Height="800"
        WindowState="Maximized" Background="#0F172A"
        KeyDown="Window_KeyDown" Closing="Window_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>

        <!-- 区域1: 导航栏 -->
        <Border Grid.Row="0" Background="#1E293B" BorderBrush="#334155" BorderThickness="0,0,0,1">
            <Grid Margin="8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="CurrentInfoText" Grid.Column="0" Text="未选择比赛" Foreground="White" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="StateIndicator" Width="10" Height="10" Fill="#F59E0B" Margin="0,0,4,0"/>
                    <TextBlock x:Name="StateLabel" Text="等待" Foreground="#94A3B8" FontSize="14"/>
                </StackPanel>
                <Button Content="&#9881; 参数设置" Grid.Column="2" Click="OpenSettings_Click" Padding="8,2" Margin="8,0,0,0"
                        Background="#475569" Foreground="White" BorderThickness="0" FontSize="13"/>
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                    <TextBlock Text="服务器:" Foreground="#94A3B8" Margin="0,0,4,0" FontSize="12"/>
                    <TextBox x:Name="ServerBox" Text="127.0.0.1:3002" Width="130" Padding="2" Background="#334155" Foreground="White" BorderBrush="#475569" FontSize="12"/>
                    <Button x:Name="ConnBtn" Content="连接" Click="Connect_Click" Padding="8,2" Margin="4,0,0,0"
                            Background="#3B82F6" Foreground="White" BorderThickness="0" FontSize="12"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 主体区域 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>

            <!-- 赛程树（左侧） -->
            <Border Grid.Column="0" Background="#1E293B" BorderBrush="#334155" BorderThickness="0,0,1,0">
                <DockPanel>
                    <Border DockPanel.Dock="Top" BorderBrush="#334155" BorderThickness="0,0,0,1" Padding="10,8">
                        <TextBlock Text="赛程导航" Foreground="#64748B" FontSize="14" FontWeight="Bold"/>
                    </Border>
                    <TreeView x:Name="ScheduleTree" Background="#1E293B" Foreground="White" FontSize="13"
                              BorderThickness="0" SelectedItemChanged="ScheduleTree_Selected" Margin="0,4,0,0"/>
                </DockPanel>
            </Border>

            <!-- 泳池图（中间） -->
            <Border Grid.Column="1" Padding="8">
                <Grid>
                    <!-- 表头 + 泳道 -->
                    <DockPanel>
                        <Grid x:Name="PoolHeader" DockPanel.Dock="Top" Height="24" Margin="0,0,0,2"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="LanePanel"/>
                        </ScrollViewer>
                    </DockPanel>
                    <!-- 右下角滚动时间 -->
                    <TextBlock x:Name="RunningTime" Text="0.0" FontSize="38" FontWeight="Bold"
                               Foreground="#F59E0B" FontFamily="Consolas" Opacity="0.9"
                               HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,12,8"
                               IsHitTestVisible="False"/>
                </Grid>
            </Border>

            <!-- 右侧操作面板 -->
            <Border Grid.Column="2" Background="#1E293B" BorderBrush="#334155" BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="8">
                    <StackPanel>
                        <!-- 比赛控制 -->
                        <TextBlock Text="比赛控制" Foreground="#64748B" FontSize="13" FontWeight="Bold" Margin="0,0,0,4"
                                   Margin="0,0,0,6"/>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Content="就  位" Grid.Column="0" Click="Ready_Click" Padding="0,7" FontSize="14" FontWeight="Bold"
                                    Background="#F59E0B" Foreground="Black" BorderThickness="0" Margin="0,0,2,0"/>
                            <Button Content="发  令" Grid.Column="1" Click="Start_Click" Padding="0,7" FontSize="14" FontWeight="Bold"
                                    Background="#22C55E" Foreground="White" BorderThickness="0" Margin="2,0,0,0"/>
                        </Grid>
                        <Button Content="计时复位" Click="TimerReset_Click" Padding="0,7" FontSize="14" FontWeight="Bold"
                                Background="#EF4444" Foreground="White" BorderThickness="0" Margin="0,0,0,4"/>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Content="全开" Grid.Column="0" Click="OpenAll_Click" Padding="0,7" FontSize="14" FontWeight="Bold"
                                    Background="#22C55E" Foreground="White" BorderThickness="0" Margin="0,0,2,0"/>
                            <Button Content="全关" Grid.Column="1" Click="CloseAll_Click" Padding="0,7" FontSize="14" FontWeight="Bold"
                                    Background="#64748B" Foreground="White" BorderThickness="0" Margin="2,0,0,0"/>
                        </Grid>
                        <Button Content="确认本组成绩" Click="Confirm_Click" Padding="0,8" FontSize="14" FontWeight="Bold"
                                Background="#3B82F6" Foreground="White" BorderThickness="0" Margin="0,0,0,4"/>

                        <!-- 泳道操作 -->
                        <TextBlock Text="泳道操作" Foreground="#64748B" FontSize="13" FontWeight="Bold" Margin="0,6,0,4"
                                   Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBox x:Name="LaneInput" Text="4" Width="46" Padding="4" FontSize="14" TextAlignment="Center"
                                     Background="#1E293B" Foreground="White" BorderBrush="#475569"/>
                            <TextBlock Text="道" Foreground="#94A3B8" FontSize="12" VerticalAlignment="Center" Margin="4,0,0,0"/>
                        </StackPanel>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Button Content="DNS" Grid.Row="0" Grid.Column="0" Click="MarkDNS_Click" Padding="0,7" FontSize="14" FontWeight="Bold"
                                    Background="#64748B" Foreground="White" BorderThickness="0" Margin="0,0,2,4"/>
                            <Button Content="DNF" Grid.Row="0" Grid.Column="1" Click="MarkDNF_Click" Padding="0,7" FontSize="14" FontWeight="Bold"
                                    Background="#78716C" Foreground="White" BorderThickness="0" Margin="2,0,0,4"/>
                            <Button Content="DSQ" Grid.Row="1" Grid.Column="0" Click="MarkDSQ_Click" Padding="0,7" FontSize="14" FontWeight="Bold"
                                    Background="#9CA3AF" Foreground="White" BorderThickness="0" Margin="0,0,2,0"/>
                            <Button Content="手动输入" Grid.Row="1" Grid.Column="1" Click="ManualTime_Click" Padding="0,7" FontSize="14" FontWeight="Bold"
                                    Background="#D97706" Foreground="White" BorderThickness="0" Margin="2,0,0,0"/>
                        </Grid>

                        <!-- 计时源对比 -->
                        <TextBlock Text="计时源对比" Foreground="#64748B" FontSize="13" FontWeight="Bold" Margin="0,6,0,4"
                                   Margin="0,0,0,6"/>
                        <TextBlock x:Name="TimingSourceInfo" Text="" Foreground="#94A3B8" FontSize="12" TextWrapping="Wrap" MinHeight="40"/>

                        <!-- 显示控制 -->
                        <TextBlock Text="显示控制" Foreground="#64748B" FontSize="13" FontWeight="Bold" Margin="0,6,0,4"
                                   Margin="0,0,0,6"/>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Button Content="出发表" Grid.Row="0" Grid.Column="0" Tag="SHOW_START_LIST" Click="DisplayBtn_Click" Padding="0,7" FontSize="14" FontWeight="Bold"
                                    Background="#3B82F6" Foreground="White" BorderThickness="0" Margin="0,0,2,4"/>
                            <Button Content="比赛视图" Grid.Row="0" Grid.Column="1" Tag="SHOW_LIVE_RACE" Click="DisplayBtn_Click" Padding="0,7" FontSize="14" FontWeight="Bold"
                                    Background="#2563EB" Foreground="White" BorderThickness="0" Margin="2,0,0,4"/>
                            <Button Content="组成绩" Grid.Row="1" Grid.Column="0" Tag="SHOW_HEAT_RESULT" Click="DisplayBtn_Click" Padding="0,7" FontSize="14" FontWeight="Bold"
                                    Background="#059669" Foreground="White" BorderThickness="0" Margin="0,0,2,4"/>
                            <Button Content="总排名" Grid.Row="1" Grid.Column="1" Tag="SHOW_EVENT_RANKING" Click="DisplayBtn_Click" Padding="0,7" FontSize="14" FontWeight="Bold"
                                    Background="#10B981" Foreground="White" BorderThickness="0" Margin="2,0,0,4"/>
                            <Button Content="团体积分" Grid.Row="2" Grid.Column="0" Tag="SHOW_TEAM_STANDINGS" Click="DisplayBtn_Click" Padding="0,7" FontSize="14" FontWeight="Bold"
                                    Background="#D97706" Foreground="White" BorderThickness="0" Margin="0,0,2,4"/>
                            <Button Content="颁奖" Grid.Row="2" Grid.Column="1" Tag="SHOW_AWARDS" Click="DisplayBtn_Click" Padding="0,7" FontSize="14" FontWeight="Bold"
                                    Background="#F59E0B" Foreground="White" BorderThickness="0" Margin="2,0,0,4"/>
                            <Button Content="纪录" Grid.Row="3" Grid.Column="0" Tag="SHOW_RECORDS" Click="DisplayBtn_Click" Padding="0,7" FontSize="14" FontWeight="Bold"
                                    Background="#DC2626" Foreground="White" BorderThickness="0" Margin="0,0,2,0"/>
                            <Button Content="欢迎" Grid.Row="3" Grid.Column="1" Tag="SHOW_WELCOME" Click="DisplayBtn_Click" Padding="0,7" FontSize="14" FontWeight="Bold"
                                    Background="#8B5CF6" Foreground="White" BorderThickness="0" Margin="2,0,0,0"/>
                        </Grid>

                        <!-- 成绩发布 -->
                        <Button Content="成绩发布" Click="PublishResult_Click" Padding="0,9" FontSize="15" FontWeight="Bold"
                                Background="#F59E0B" Foreground="White" BorderThickness="0" Margin="0,4,0,0"/>

                        <!-- 抢跳信息 -->
                        <TextBlock x:Name="FalseStartInfo" Text="" Foreground="#EF4444" FontSize="11"
                                   TextWrapping="Wrap" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- 区域5: 底部 -->
        <Border Grid.Row="2" Background="#1E293B" BorderBrush="#334155" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="180"/>
                </Grid.ColumnDefinitions>
                <DockPanel Grid.Column="0" Margin="8,4">
                    <TextBlock DockPanel.Dock="Top" Text="出发表" Foreground="#64748B" FontSize="10" Margin="0,0,0,2" FontWeight="Bold"/>
                    <TextBlock x:Name="StartListText" Text="" Foreground="#94A3B8" FontSize="13" TextWrapping="Wrap"/>
                </DockPanel>
                <Border Grid.Column="1" BorderBrush="#334155" BorderThickness="1,0,0,0">
                    <DockPanel Margin="8,4">
                        <TextBlock DockPanel.Dock="Top" Text="日志" Foreground="#64748B" FontSize="10" Margin="0,0,0,2" FontWeight="Bold"/>
                        <ListBox x:Name="LogList" FontSize="13" Foreground="#94A3B8" Background="Transparent"
                                 BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                    </DockPanel>
                </Border>
                <Border Grid.Column="2" BorderBrush="#334155" BorderThickness="1,0,0,0">
                    <StackPanel Margin="8,4">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="WsConn" Width="8" Height="8" Fill="#EF4444" Margin="0,0,4,0"/>
                            <TextBlock x:Name="WsConnText" Text="服务器: 未连接" Foreground="#94A3B8" FontSize="13"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <Ellipse x:Name="HwConn" Width="8" Height="8" Fill="#EF4444" Margin="0,0,4,0"/>
                            <TextBlock x:Name="HwConnText" Text="计时硬件: 未连接" Foreground="#94A3B8" FontSize="13"/>
                        </StackPanel>
                        <TextBlock x:Name="ControlModeText" Text="控制模式: -" Foreground="#64748B" FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
