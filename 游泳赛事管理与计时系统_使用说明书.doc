</tr></thead><tbody>
<tr>
  <td>4</td>
  <td>张三</td>
  <td>上海</td>
  <td><strong>27.50</strong>&lt;br&gt;(27.50)</td>
  <td><strong>57.20</strong>&lt;br&gt;(29.70)</td>
  <td><strong>1:27.30</strong>&lt;br&gt;(30.10)</td>
  <td><strong>1:58.45</strong>&lt;br&gt;(31.15)</td>
